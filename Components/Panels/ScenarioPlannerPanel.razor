@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Inputs
@using WileyCoWeb.State

<div id="scenario-panel" class="space-y-4" aria-live="polite">
    <section id="scenario-summary-panel" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Scenario Summary</p>
        <div class="mt-3 grid gap-4 md:grid-cols-2" role="group" aria-label="Scenario summary metrics">
            <SfNumericTextBox TValue="decimal" Value="@ScenarioAdjustedRate" Enabled="false" Placeholder="Scenario Adjusted Rate" FloatLabelType="FloatLabelType.Auto" Width="100%" Format="C2" />
            <SfNumericTextBox TValue="decimal" Value="@ScenarioCostTotal" Enabled="false" Placeholder="Scenario Cost Total" FloatLabelType="FloatLabelType.Auto" Width="100%" Format="C0" />
            <SfNumericTextBox TValue="decimal" Value="@ScenarioAdjustedDelta" Enabled="false" Placeholder="Scenario Delta" FloatLabelType="FloatLabelType.Auto" Width="100%" Format="C2" />
            <SfNumericTextBox TValue="decimal" Value="@CurrentRate" Enabled="false" Placeholder="Current Rate" FloatLabelType="FloatLabelType.Auto" Width="100%" Format="C2" />
        </div>
    </section>

    <section id="scenario-metrics-panel" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Scenario Metrics</p>
        <div class="mt-3 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <SfCard>
                <CardHeader Title="Base Break-Even" SubTitle="@BreakEvenRateDisplay" />
                <CardContent Content="Calculated from current costs and projected volume." />
            </SfCard>
            <SfCard>
                <CardHeader Title="Scenario Break-Even" SubTitle="@ScenarioAdjustedRateDisplay" />
                <CardContent Content="Includes the active scenario cost items." />
            </SfCard>
            <SfCard>
                <CardHeader Title="Scenario Cost Total" SubTitle="@ScenarioCostTotalDisplay" />
                <CardContent Content="Added pressure from the selected what-if items." />
            </SfCard>
            <SfCard>
                <CardHeader Title="Scenario Delta" SubTitle="@ScenarioAdjustedDeltaDisplay" />
                <CardContent Content="Gap between the current rate and adjusted break-even." />
            </SfCard>
        </div>
    </section>

    <section id="scenario-grid-panel" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Scenario Grid</p>
        <div class="mt-3 space-y-3">
            <SfGrid ID="scenario-grid" TValue="ScenarioItem" DataSource="@ScenarioItems" Toolbar="@ScenarioToolbarItems" AllowPaging="false" AllowSorting="true" AllowEditing="true" AllowAdding="true" AllowDeleting="true" AllowTextWrap="true" Height="420">
                <GridEvents TValue="ScenarioItem" OnActionComplete="OnScenarioGridActionComplete" />
                <GridEditSettings AllowAdding="true" AllowEditing="true" AllowDeleting="true" Mode="Syncfusion.Blazor.Grids.EditMode.Dialog" />
                <GridTemplates>
                    <EmptyRecordTemplate>
                        <div class="flex min-h-[16rem] flex-col items-center justify-center gap-3 rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center">
                            <div>
                                <div class="text-sm font-semibold text-slate-900">No scenarios yet</div>
                                <div class="mt-2 text-sm text-slate-600">Add your first what-if item to see how it changes break-even and rate pressure.</div>
                            </div>
                            <div class="text-xs text-slate-500">Use the Add toolbar button above to create the first scenario row.</div>
                        </div>
                    </EmptyRecordTemplate>
                </GridTemplates>
                <GridColumns>
                    <GridColumn Field=@nameof(ScenarioItem.Id) IsPrimaryKey="true" Visible="false" IsIdentity="false" Width="0" />
                    <GridColumn Field=@nameof(ScenarioItem.Name) HeaderText="Scenario Item" Width="180" />
                    <GridColumn Field=@nameof(ScenarioItem.Cost) HeaderText="Cost" Format="C0" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" Width="120" />
                </GridColumns>
            </SfGrid>
            <p id="scenario-edit-status" role="status" aria-live="polite" class="text-xs text-slate-500">Scenario edits update the workspace draft immediately. Use Save scenario in the sidebar to persist the current scenario to Aurora.</p>
        </div>
    </section>
</div>

@code {
    [Parameter] public decimal ScenarioAdjustedRate { get; set; }
    [Parameter] public decimal ScenarioCostTotal { get; set; }
    [Parameter] public decimal ScenarioAdjustedDelta { get; set; }
    [Parameter] public decimal CurrentRate { get; set; }
    [Parameter] public string BreakEvenRateDisplay { get; set; } = string.Empty;
    [Parameter] public string ScenarioAdjustedRateDisplay { get; set; } = string.Empty;
    [Parameter] public string ScenarioCostTotalDisplay { get; set; } = string.Empty;
    [Parameter] public string ScenarioAdjustedDeltaDisplay { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<ScenarioItem> ScenarioItems { get; set; } = [];
    [Parameter] public IReadOnlyList<string> ScenarioToolbarItems { get; set; } = [];
    [Parameter] public EventCallback<Syncfusion.Blazor.Grids.ActionEventArgs<ScenarioItem>> OnScenarioGridActionComplete { get; set; }
}
