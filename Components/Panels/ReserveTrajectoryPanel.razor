@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Charts
@using WileyCoWeb.Contracts

<section id="reserve-trajectory-panel" class="space-y-4">
    <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-col gap-2">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Reserve Trajectory</p>
            <p class="text-sm text-slate-600">A live reserve forecast with a shaded stress band and policy floor carried through the workspace snapshot.</p>
        </div>

        <div class="mt-4 grid gap-4 md:grid-cols-3">
            <SfCard>
                <CardHeader Title="Current Reserves" SubTitle="@CurrentReservesDisplay" />
                <CardContent Content="The current reserve balance from the workspace forecast." />
            </SfCard>
            <SfCard>
                <CardHeader Title="Current Reserve Months" SubTitle="@CurrentReserveMonthsDisplay" />
                <CardContent Content="An estimated reserve coverage horizon versus the policy floor." />
            </SfCard>
            <SfCard>
                <CardHeader Title="5-Year Solvency Score" SubTitle="@FiveYearSolvencyScoreDisplay" />
                <CardContent Content="How the five-year forecast compares with the policy minimum." />
            </SfCard>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
            <SfButton id="reserve-trajectory-export-pdf-button"
                      CssClass="e-primary"
                      IsPrimary="true"
                      Disabled="@(!CanExportPdf)"
                      OnClick="HandleExportPdfAsync">
                Export PDF
            </SfButton>
            <SfButton id="reserve-trajectory-export-excel-button"
                      Disabled="@(!CanExportExcel)"
                      OnClick="HandleExportExcelAsync">
                Export Excel
            </SfButton>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-col gap-2">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Forecast Chart</p>
            <p class="text-sm text-slate-600">Projected reserve balance versus the recommended reserve line.</p>
        </div>

        @if (HasTrajectory)
        {
            <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-3">
                <SfChart ID="@ChartId"
                         Title="Reserve forecast"
                         AccessibilityDescription="Area chart showing reserve projection, stress band, and policy minimum over time."
                         EnableAnimation="true"
                         UseGroupingSeparator="true"
                         Width="100%"
                         Height="320px">
                    <ChartArea>
                        <ChartAreaBorder Width="0"></ChartAreaBorder>
                    </ChartArea>
                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.DateTime" LabelFormat="MMM yy">
                        <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                    </ChartPrimaryXAxis>
                    <ChartPrimaryYAxis LabelFormat="C0">
                        <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                    </ChartPrimaryYAxis>
                    <ChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Top"></ChartLegendSettings>
                    <ChartTooltipSettings Enable="true" Shared="false" Format="${point.x}: ${point.y:C0}" />
                    <ChartCrosshairSettings Enable="true" LineType="LineType.Both">
                        <ChartCrosshairLine Color="#94a3b8" Width="1" />
                    </ChartCrosshairSettings>
                    <ChartSeriesCollection>
                        <ChartSeries DataSource="@ForecastPoints"
                                     XName="@nameof(WorkspaceReserveTrajectoryPointData.DateUtc)"
                                     YName="@nameof(WorkspaceReserveTrajectoryPointData.PredictedReserves)"
                                     Type="ChartSeriesType.Area"
                                     Name="Projected reserves"
                                     Fill="#0f766e"
                                     Opacity="0.2"
                                     Width="3">
                            <ChartSeriesBorder Width="2" Color="#0f766e" />
                            <ChartMarker Visible="true" Width="8" Height="8" Fill="#0f766e" />
                        </ChartSeries>
                        <ChartSeries DataSource="@StressBandPoints"
                                     XName="@nameof(ReserveBandPoint.DateUtc)"
                                     YName="@nameof(ReserveBandPoint.High)"
                                     Type="ChartSeriesType.Line"
                                     Name="Confidence upper"
                                     Fill="#93c5fd"
                                     Width="1"
                                     DashArray="4,4">
                            <ChartMarker Visible="false" />
                        </ChartSeries>
                        <ChartSeries DataSource="@StressBandPoints"
                                     XName="@nameof(ReserveBandPoint.DateUtc)"
                                     YName="@nameof(ReserveBandPoint.Low)"
                                     Type="ChartSeriesType.Line"
                                     Name="Confidence lower"
                                     Fill="#93c5fd"
                                     Width="1"
                                     DashArray="4,4">
                            <ChartMarker Visible="false" />
                        </ChartSeries>
                        <ChartSeries DataSource="@PolicyMinimumPoints"
                                     XName="@nameof(ReservePolicyPoint.DateUtc)"
                                     YName="@nameof(ReservePolicyPoint.PolicyMinimum)"
                                     Type="ChartSeriesType.Line"
                                     Name="Policy minimum"
                                     Fill="#b45309"
                                     Width="2"
                                     DashArray="6,4">
                            <ChartMarker Visible="false" />
                        </ChartSeries>
                    </ChartSeriesCollection>
                </SfChart>
                <div class="mt-3 grid gap-3 md:grid-cols-2">
                    <div class="rounded-xl bg-white/80 px-3 py-2 text-xs text-slate-600">
                        <span class="font-semibold text-slate-900">Stress band:</span> Forecast plus or minus the current confidence interval.
                    </div>
                    <div class="rounded-xl bg-amber-50 px-3 py-2 text-xs text-amber-900">
                        <span class="font-semibold text-amber-950">Policy minimum:</span> @PolicyMinimumDisplay
                    </div>
                </div>
                <p class="mt-2 text-xs text-slate-500">Risk assessment: @RiskAssessmentDisplay</p>
                <p class="mt-3 text-xs text-slate-500">Latest confidence interval: @LatestConfidenceIntervalDisplay</p>
            </div>
        }
        else
        {
            <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-600">
                Reserve forecast data is not available yet. Once the workspace snapshot includes forecast points, the chart will appear here.
            </div>
        }
    </section>
</section>

@code {
    [Parameter] public WorkspaceReserveTrajectoryData? Trajectory { get; set; }
    [Parameter] public EventCallback OnExportPdf { get; set; }
    [Parameter] public EventCallback OnExportExcel { get; set; }

    private bool HasTrajectory => Trajectory?.ForecastPoints is { Count: > 0 };
    private bool CanExportPdf => OnExportPdf.HasDelegate;
    private bool CanExportExcel => OnExportExcel.HasDelegate;

    private IReadOnlyList<WorkspaceReserveTrajectoryPointData> ForecastPoints => Trajectory?.ForecastPoints ?? [];

    private IReadOnlyList<ReserveBandPoint> StressBandPoints => HasTrajectory
        ? ForecastPoints.Select(BuildStressBandPoint).ToList()
        : [];

    private IReadOnlyList<ReservePolicyPoint> PolicyMinimumPoints => HasTrajectory
        ? ForecastPoints.Select(point => new ReservePolicyPoint(point.DateUtc, PolicyMinimumValue)).ToList()
        : [];

    private string CurrentReservesDisplay => Trajectory is null ? "Unavailable" : Trajectory.CurrentReserves.ToString("C0");

    private string CurrentReserveMonthsDisplay => Trajectory is null || PolicyMinimumValue <= 0m
        ? "Unavailable"
        : $"{CurrentReserveMonths:0.0} months";

    private string FiveYearSolvencyScoreDisplay => Trajectory is null || !HasTrajectory || PolicyMinimumValue <= 0m
        ? "Unavailable"
        : $"{FiveYearSolvencyScore:0}%";

    private string PolicyMinimumDisplay => Trajectory is null ? "Unavailable" : Trajectory.RecommendedReserveLevel.ToString("C0");

    private decimal PolicyMinimumValue => Trajectory?.RecommendedReserveLevel ?? 0m;

    private decimal CurrentReserveMonths => Trajectory is null || PolicyMinimumValue <= 0m
        ? 0m
        : Math.Round((Trajectory.CurrentReserves / PolicyMinimumValue) * 12m, 1, MidpointRounding.AwayFromZero);

    private decimal FiveYearSolvencyScore => Trajectory is null || !HasTrajectory || PolicyMinimumValue <= 0m
        ? 0m
        : Math.Round(ClampDecimal((ForecastPoints[^1].PredictedReserves / PolicyMinimumValue) * 100m, 0m, 100m), 0, MidpointRounding.AwayFromZero);

    private string RiskAssessmentDisplay => string.IsNullOrWhiteSpace(Trajectory?.RiskAssessment) ? "Unavailable" : Trajectory!.RiskAssessment;

    private string LatestConfidenceIntervalDisplay => HasTrajectory ? ForecastPoints[^1].ConfidenceInterval.ToString("C0") : "Unavailable";

    private static string ChartId => "reserve-trajectory-chart";

    private static ReserveBandPoint BuildStressBandPoint(WorkspaceReserveTrajectoryPointData point)
    {
        var low = Math.Max(0m, point.PredictedReserves - point.ConfidenceInterval);
        var high = point.PredictedReserves + point.ConfidenceInterval;
        return new ReserveBandPoint(point.DateUtc, low, high);
    }

    private Task HandleExportPdfAsync() => OnExportPdf.InvokeAsync();

    private Task HandleExportExcelAsync() => OnExportExcel.InvokeAsync();

    private static decimal ClampDecimal(decimal value, decimal minimum, decimal maximum)
    {
        if (value < minimum)
        {
            return minimum;
        }

        if (value > maximum)
        {
            return maximum;
        }

        return value;
    }

    private sealed record ReserveBandPoint(DateTime DateUtc, decimal Low, decimal High);

    private sealed record ReservePolicyPoint(DateTime DateUtc, decimal PolicyMinimum);
}