@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Charts
@using Syncfusion.Blazor.CircularGauge
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.ProgressBar
@using Syncfusion.Blazor.Spinner
@using WileyCoWeb.Contracts

<div id="break-even-panel" class="space-y-4">

    
    <SfCard ID="break-even-input-card" CssClass="wiley-panel-card">
        <CardHeader Title="Break-Even Inputs"
                    SubTitle="Enter total operating costs and projected customer volume to compute the break-even rate." />
        <CardContent>
            <SfProgressBar Type="ProgressType.Linear"
                           IsIndeterminate="@IsSavingBaseline"
                           Visible="@IsSavingBaseline"
                           Value="100"
                           Maximum="100"
                           ShowProgressValue="false"
                           Height="4px"
                           TrackColor="transparent"
                           ProgressColor="#0e7490" />

            <div id="break-even-input-row" class="mt-3 grid gap-4 md:grid-cols-2">
                <SfTooltip Content="Total annual or monthly operating costs across all enterprises."
                           Position="Syncfusion.Blazor.Popups.Position.TopCenter"
                           OpensOn="Hover Focus"
                           ShowTipPointer="true"
                           CloseDelay="200">
                    <SfNumericTextBox TValue="decimal"
                                      ID="break-even-total-costs"
                                      Value="@TotalCosts"
                                      Placeholder="Total Costs"
                                      FloatLabelType="FloatLabelType.Auto"
                                      ShowSpinButton="false"
                                      Min="0"
                                      Width="100%"
                                      Format="C0">
                        <NumericTextBoxEvents TValue="decimal" ValueChange="OnTotalCostsChanged" />
                    </SfNumericTextBox>
                </SfTooltip>

                <SfTooltip Content="Expected number of billable customers for the rate period."
                           Position="Syncfusion.Blazor.Popups.Position.TopCenter"
                           OpensOn="Hover Focus"
                           ShowTipPointer="true"
                           CloseDelay="200">
                    <SfNumericTextBox TValue="decimal"
                                      ID="break-even-projected-volume"
                                      Value="@ProjectedVolume"
                                      Placeholder="Projected Volume"
                                      FloatLabelType="FloatLabelType.Auto"
                                      ShowSpinButton="false"
                                      Min="0"
                                      Step="1"
                                      Width="100%"
                                      Format="N0">
                        <NumericTextBoxEvents TValue="decimal" ValueChange="OnProjectedVolumeChanged" />
                    </SfNumericTextBox>
                </SfTooltip>
            </div>

            <div id="break-even-actions" class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div class="relative inline-flex items-center gap-2">
                    <SfTooltip Content="Persist these inputs as the workspace baseline for all future rate scenarios."
                               Position="Syncfusion.Blazor.Popups.Position.TopCenter"
                               OpensOn="Hover Focus"
                               ShowTipPointer="true"
                               CloseDelay="200">
                        <SfButton CssClass="e-primary"
                                  IsPrimary="true"
                                  Disabled="@IsSavingBaseline"
                                  OnClick="OnSaveWorkspaceBaseline">
                            @(IsSavingBaseline ? "Saving baseline..." : "Save workspace baseline")
                        </SfButton>
                    </SfTooltip>
                    <div class="wiley-panel-spinner-host" style="height:20px;width:20px;">
                        <SfSpinner Visible="@IsSavingBaseline" Size="18" Label="" Type="SpinnerType.Material" />
                    </div>
                </div>
                <span id="baseline-save-status" role="status" aria-live="polite" class="text-xs text-slate-500">@BaselineSaveStatus</span>
            </div>
        </CardContent>
    </SfCard>

    
    <section id="break-even-quadrant-panel" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="mb-4 flex flex-col gap-1">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Break-Even Quadrants</p>
            <p class="text-sm text-slate-600">Normalized to $/customer · Water · Sewer · Trash · Apartments</p>
        </div>

        <div id="break-even-quadrant-grid" class="grid gap-4 lg:grid-cols-2 auto-rows-fr">
            @foreach (var quadrant in VisibleQuadrants)
            {
                var adequacy = GetRateAdequacy(quadrant);
                var adequacyCss = GetRateAdequacyCssClass(quadrant);
                var adequacyLabel = GetRateAdequacyLabel(quadrant);

                <section id="@GetQuadrantSectionId(quadrant)" class="flex h-full flex-col rounded-2xl border border-slate-200 bg-slate-50 shadow-sm overflow-hidden">

                    
                    <div class="flex items-center justify-between bg-[#0f172a] px-4 py-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">@quadrant.EnterpriseType</p>
                            <h3 class="text-base font-semibold text-white">@quadrant.EnterpriseName</h3>
                        </div>
                        <span class="rounded-full px-2 py-0.5 text-xs font-semibold @adequacyCss bg-white/10 text-white">
                            @adequacy.ToString("N0")%
                        </span>
                    </div>

                    <div class="flex flex-1 flex-col gap-3 p-4">

                        
                        <div class="grid grid-cols-3 gap-2 text-center">
                            <SfTooltip Content="Current rate charged per customer per month."
                                       Position="Syncfusion.Blazor.Popups.Position.TopCenter"
                                       OpensOn="Hover Focus"
                                       ShowTipPointer="true"
                                       CloseDelay="200">
                                <div class="rounded-xl border border-slate-200 bg-white p-2 shadow-sm">
                                    <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">Current</p>
                                    <p class="mt-0.5 text-sm font-bold text-slate-900">@quadrant.CurrentRate.ToString("C2")</p>
                                </div>
                            </SfTooltip>
                            <SfTooltip Content="Rate required to exactly cover all operating expenses."
                                       Position="Syncfusion.Blazor.Popups.Position.TopCenter"
                                       OpensOn="Hover Focus"
                                       ShowTipPointer="true"
                                       CloseDelay="200">
                                <div class="rounded-xl border border-slate-200 bg-white p-2 shadow-sm">
                                    <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">Break-Even</p>
                                    <p class="mt-0.5 text-sm font-bold text-slate-900">@quadrant.BreakEvenRate.ToString("C2")</p>
                                </div>
                            </SfTooltip>
                            <SfTooltip Content="Net surplus or deficit per customer per month at current rate."
                                       Position="Syncfusion.Blazor.Popups.Position.TopCenter"
                                       OpensOn="Hover Focus"
                                       ShowTipPointer="true"
                                       CloseDelay="200">
                                <div class="rounded-xl border border-slate-200 bg-white p-2 shadow-sm">
                                    <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">Balance</p>
                                    <p class="mt-0.5 text-sm font-bold @(quadrant.MonthlyBalance >= 0 ? "text-emerald-600" : "text-rose-600")">
                                        @quadrant.MonthlyBalance.ToString("C0")
                                    </p>
                                </div>
                            </SfTooltip>
                        </div>

                        
                        <div class="flex flex-col items-center gap-1">
                            <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500">Rate Adequacy</p>
                            <SfCircularGauge ID="@GetQuadrantGaugeId(quadrant)"
                                             AllowMargin="true"
                                             AnimationDuration="700"
                                             Width="100%"
                                             Height="160px"
                                             Background="transparent">
                                <CircularGaugeAxes>
                                    <CircularGaugeAxis Minimum="0"
                                                       Maximum="150"
                                                       StartAngle="210"
                                                       EndAngle="150"
                                                       Radius="80%">
                                        <CircularGaugeAxisLineStyle Width="8" Color="transparent" />
                                        <CircularGaugeAxisLabelStyle>
                                            <CircularGaugeAxisLabelFont Size="0px" />
                                        </CircularGaugeAxisLabelStyle>
                                        <CircularGaugeAxisMajorTicks Height="0" />
                                        <CircularGaugeAxisMinorTicks Height="0" />
                                        <CircularGaugeRanges>
                                            <CircularGaugeRange Start="0" End="85" Color="#fca5a5" StartWidth="8" EndWidth="8" />
                                            <CircularGaugeRange Start="85" End="100" Color="#fde68a" StartWidth="8" EndWidth="8" />
                                            <CircularGaugeRange Start="100" End="150" Color="#6ee7b7" StartWidth="8" EndWidth="8" />
                                        </CircularGaugeRanges>
                                        <CircularGaugePointers>
                                            <CircularGaugePointer Value="@adequacy"
                                                                  Radius="70%"
                                                                  Color="#0f172a"
                                                                  PointerWidth="8" />
                                        </CircularGaugePointers>
                                    </CircularGaugeAxis>
                                </CircularGaugeAxes>
                            </SfCircularGauge>
                            <p class="text-xs font-medium @adequacyCss">@adequacyLabel</p>
                            <p class="text-[10px] text-slate-400">@adequacy.ToString("N0")% of break-even covered</p>
                        </div>

                        
                        <div class="rounded-xl border border-slate-200 bg-white p-2">
                            <SfChart ID="@GetQuadrantChartId(quadrant)"
                                     Title="@($"{quadrant.EnterpriseName} break-even")"
                                     AccessibilityDescription="@($"Line chart showing revenue, expenses, and break-even for {quadrant.EnterpriseName}.")"
                                     EnableAnimation="true"
                                     UseGroupingSeparator="true"
                                     Width="100%"
                                     Height="300px"
                                     Background="transparent"
                                     Theme="Syncfusion.Blazor.Theme.Fluent2">
                                <ChartArea>
                                    <ChartAreaBorder Width="0" />
                                </ChartArea>
                                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category"
                                                   LabelIntersectAction="LabelIntersectAction.Rotate45">
                                    <ChartAxisMajorGridLines Width="0" />
                                </ChartPrimaryXAxis>
                                <ChartPrimaryYAxis LabelFormat="C2">
                                    <ChartAxisLineStyle Width="0" />
                                </ChartPrimaryYAxis>
                                <ChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Top" />
                                <ChartZoomSettings EnableSelectionZooming="true" EnableScrollbar="false" />
                                <ChartTooltipSettings Enable="true" Shared="false" Format="${point.x} : ${point.y}" />
                                <ChartSeriesCollection>
                                    <ChartSeries DataSource="@quadrant.SeriesPoints"
                                                 XName="@nameof(BreakEvenSeriesPoint.PeriodLabel)"
                                                 YName="@nameof(BreakEvenSeriesPoint.RevenuePerCustomer)"
                                                 Type="ChartSeriesType.Line"
                                                 Name="Revenue"
                                                 Fill="#15803d"
                                                 Width="3">
                                        <ChartMarker Visible="true" Width="8" Height="8" Fill="#15803d" />
                                    </ChartSeries>
                                    <ChartSeries DataSource="@quadrant.SeriesPoints"
                                                 XName="@nameof(BreakEvenSeriesPoint.PeriodLabel)"
                                                 YName="@nameof(BreakEvenSeriesPoint.ExpensesPerCustomer)"
                                                 Type="ChartSeriesType.Line"
                                                 Name="Expenses"
                                                 Fill="#dc2626"
                                                 Width="3">
                                        <ChartMarker Visible="true" Width="8" Height="8" Fill="#dc2626" />
                                    </ChartSeries>
                                    <ChartSeries DataSource="@quadrant.SeriesPoints"
                                                 XName="@nameof(BreakEvenSeriesPoint.PeriodLabel)"
                                                 YName="@nameof(BreakEvenSeriesPoint.BreakEvenPerCustomer)"
                                                 Type="ChartSeriesType.Line"
                                                 Name="Break-Even"
                                                 Fill="#111827"
                                                 Width="2"
                                                 DashArray="6,4">
                                        <ChartMarker Visible="false" />
                                    </ChartSeries>
                                </ChartSeriesCollection>
                            </SfChart>
                        </div>

                    </div>
                </section>
            }
        </div>
    </section>

    <ApartmentConfigPanel UnitTypes="@ApartmentUnitTypes" OnUnitTypesChanged="OnApartmentUnitTypesChanged" />
</div>
