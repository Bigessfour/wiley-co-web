@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Charts
@using Syncfusion.Blazor.Inputs
@using WileyCoWeb.Contracts

<div id="break-even-panel" class="space-y-4">
    <section id="break-even-input-panel" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Break-Even Inputs</p>
        <div id="break-even-input-row" class="mt-3 grid gap-4 md:grid-cols-2">
            <SfNumericTextBox TValue="decimal"
                              Value="@TotalCosts"
                              Placeholder="Total Costs"
                              FloatLabelType="FloatLabelType.Auto"
                              ShowSpinButton="false"
                              Min="0"
                              Width="100%"
                              Format="C0">
                <NumericTextBoxEvents TValue="decimal" ValueChange="OnTotalCostsChanged" />
            </SfNumericTextBox>
            <SfNumericTextBox TValue="decimal"
                              Value="@ProjectedVolume"
                              Placeholder="Projected Volume"
                              FloatLabelType="FloatLabelType.Auto"
                              ShowSpinButton="false"
                              Min="0"
                              Step="1"
                              Width="100%"
                              Format="N0">
                <NumericTextBoxEvents TValue="decimal" ValueChange="OnProjectedVolumeChanged" />
            </SfNumericTextBox>
        </div>

        <div id="break-even-actions" class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsSavingBaseline" OnClick="OnSaveWorkspaceBaseline">
                @(IsSavingBaseline ? "Saving baseline..." : "Save workspace baseline")
            </SfButton>
            <p id="baseline-save-status" role="status" aria-live="polite" class="text-xs text-slate-500">@BaselineSaveStatus</p>
        </div>
    </section>

    <section id="break-even-quadrant-panel" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-col gap-2">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Break-Even Quadrants</p>
            <p class="text-sm text-slate-600">Normalized to $/customer for Water, Sewer, Trash, and Apartments.</p>
        </div>

        <div id="break-even-quadrant-grid" class="mt-4 grid gap-4 lg:grid-cols-2 auto-rows-fr">
            @foreach (var quadrant in VisibleQuadrants)
            {
                <section class="flex h-full flex-col rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
                    <div class="flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">@quadrant.EnterpriseName</p>
                            <h3 class="mt-1 text-lg font-semibold text-slate-900">@quadrant.EnterpriseType</h3>
                            <p class="mt-1 text-sm text-slate-600">@quadrant.EffectiveCustomerCount.ToString("N0") effective customers</p>
                        </div>
                        <SfCard>
                            <CardHeader Title="KPI Summary" SubTitle="@GetQuadrantSummary(quadrant)" />
                            <CardContent Content="Current rate, balance, and break-even are normalized to $/customer." />
                        </SfCard>
                    </div>

                    <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-3">
                        <SfChart ID="@GetQuadrantChartId(quadrant)"
                                 Title="@($"{quadrant.EnterpriseName} break-even")"
                                 AccessibilityDescription="@($"Line chart showing revenue, expenses, and break-even for {quadrant.EnterpriseName}.")"
                                 EnableAnimation="true"
                                 UseGroupingSeparator="true"
                                 Width="100%"
                                 Height="320px">
                            <ChartArea>
                                <ChartAreaBorder Width="0"></ChartAreaBorder>
                            </ChartArea>
                            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category" LabelIntersectAction="LabelIntersectAction.Rotate45">
                                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                            </ChartPrimaryXAxis>
                            <ChartPrimaryYAxis LabelFormat="C2">
                                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                            </ChartPrimaryYAxis>
                            <ChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Top"></ChartLegendSettings>
                            <ChartTooltipSettings Enable="true" Shared="false" Format="${point.x}: ${point.y}" />
                            <ChartSeriesCollection>
                                <ChartSeries DataSource="@quadrant.SeriesPoints"
                                             XName="@nameof(BreakEvenSeriesPoint.PeriodLabel)"
                                             YName="@nameof(BreakEvenSeriesPoint.RevenuePerCustomer)"
                                             Type="ChartSeriesType.Line"
                                             Name="Revenue"
                                             Fill="#15803d"
                                             Width="3">
                                    <ChartMarker Visible="true" Width="8" Height="8" Fill="#15803d" />
                                </ChartSeries>
                                <ChartSeries DataSource="@quadrant.SeriesPoints"
                                             XName="@nameof(BreakEvenSeriesPoint.PeriodLabel)"
                                             YName="@nameof(BreakEvenSeriesPoint.ExpensesPerCustomer)"
                                             Type="ChartSeriesType.Line"
                                             Name="Expenses"
                                             Fill="#dc2626"
                                             Width="3">
                                    <ChartMarker Visible="true" Width="8" Height="8" Fill="#dc2626" />
                                </ChartSeries>
                                <ChartSeries DataSource="@quadrant.SeriesPoints"
                                             XName="@nameof(BreakEvenSeriesPoint.PeriodLabel)"
                                             YName="@nameof(BreakEvenSeriesPoint.BreakEvenPerCustomer)"
                                             Type="ChartSeriesType.Line"
                                             Name="Break-Even"
                                             Fill="#111827"
                                             Width="2"
                                             DashArray="6,4">
                                    <ChartMarker Visible="false" />
                                </ChartSeries>
                            </ChartSeriesCollection>
                        </SfChart>
                    </div>
                </section>
            }
        </div>
    </section>

    <ApartmentConfigPanel UnitTypes="@ApartmentUnitTypes" OnUnitTypesChanged="OnApartmentUnitTypesChanged" />
</div>
