@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Charts
@using Syncfusion.Blazor.CircularGauge
@using WileyCoWeb.Contracts
@using WileyCoWeb.State

<div class="space-y-6" id="data-dashboard-panel">

    @* ─── KPI ROW ────────────────────────────────────────────────────────────── *@
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <SfCard ID="kpi-net-position">
            <CardHeader Title="Net Monthly Position" SubTitle="@(SelectedEnterprise + " · FY" + SelectedFiscalYear)" />
            <CardContent>
                <p class="text-2xl font-bold @(NetPosition >= 0 ? "text-emerald-600" : "text-rose-600")">@NetPosition.ToString("C0")</p>
                <p class="mt-1 text-xs text-slate-500">Monthly Revenue @MonthlyRevenue.ToString("C0") − Total Costs @TotalCosts.ToString("C0")</p>
            </CardContent>
        </SfCard>
        <SfCard ID="kpi-coverage-ratio">
            <CardHeader Title="Coverage Ratio" SubTitle="Revenue ÷ Costs" />
            <CardContent>
                <p class="text-2xl font-bold @(CoverageRatio >= 1.25 ? "text-emerald-600" : (CoverageRatio >= 1.0 ? "text-amber-600" : "text-rose-600"))">@CoverageRatio.ToString("F2")×</p>
                <p class="mt-1 text-xs text-slate-500">Target ≥ 1.25×</p>
            </CardContent>
        </SfCard>
        <SfCard ID="kpi-rate-adequacy">
            <CardHeader Title="Rate Adequacy" SubTitle="Current ÷ Break-Even" />
            <CardContent>
                <p class="text-2xl font-bold @(RateAdequacy >= 100 ? "text-emerald-600" : (RateAdequacy >= 85 ? "text-amber-600" : "text-rose-600"))">@RateAdequacy.ToString("F1")%</p>
                <p class="mt-1 text-xs text-slate-500">Current @CurrentRate.ToString("C2") · Break-Even @RecommendedRate.ToString("C2")</p>
            </CardContent>
        </SfCard>
        <SfCard ID="kpi-scenario-pressure">
            <CardHeader Title="Scenario Pressure" SubTitle="What-if cost additions" />
            <CardContent>
                <p class="text-2xl font-bold @(ScenarioCostTotal > 0 ? "text-amber-600" : "text-slate-500")">@ScenarioCostTotal.ToString("C0")</p>
                <p class="mt-1 text-xs text-slate-500">Scenario break-even @AdjustedRecommendedRate.ToString("C2")</p>
            </CardContent>
        </SfCard>
    </div>

    @* ─── CIRCULAR GAUGES ────────────────────────────────────────────────────── *@
    <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm" role="img" aria-label="Coverage ratio gauge showing revenue divided by costs">
            <p class="mb-1 text-sm font-semibold text-slate-700">Coverage Ratio</p>
            <p class="mb-2 text-xs text-slate-500">Revenue ÷ Costs · Target ≥ 1.25×</p>
            <SfCircularGauge ID="coverage-ratio-gauge"
                             EnableGroupingSeparator="false"
                             AllowMargin="true"
                             AnimationDuration="700"
                             Width="100%"
                             Height="200px">
                <CircularGaugeAxes>
                    <CircularGaugeAxis Minimum="0" Maximum="2.5" StartAngle="210" EndAngle="150" Radius="80%">
                        <CircularGaugeAxisLineStyle Width="8" Color="#e2e8f0" />
                        <CircularGaugeAxisLabelStyle Format="{value}×">
                            <CircularGaugeAxisLabelFont Size="10px" />
                        </CircularGaugeAxisLabelStyle>
                        <CircularGaugeRanges>
                            <CircularGaugeRange Start="0" End="1.0" Color="#fca5a5" StartWidth="8" EndWidth="8" />
                            <CircularGaugeRange Start="1.0" End="1.25" Color="#fde68a" StartWidth="8" EndWidth="8" />
                            <CircularGaugeRange Start="1.25" End="2.5" Color="#6ee7b7" StartWidth="8" EndWidth="8" />
                        </CircularGaugeRanges>
                        <CircularGaugePointers>
                            <CircularGaugePointer Value="@Math.Min(CoverageRatio, 2.5)" Radius="70%" Color="#0f172a" />
                        </CircularGaugePointers>
                    </CircularGaugeAxis>
                </CircularGaugeAxes>
            </SfCircularGauge>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm" role="img" aria-label="Rate adequacy gauge showing current rate versus break-even rate">
            <p class="mb-1 text-sm font-semibold text-slate-700">Rate Adequacy</p>
            <p class="mb-2 text-xs text-slate-500">Current ÷ Break-Even · Target ≥ 100%</p>
            <SfCircularGauge ID="rate-adequacy-gauge"
                             EnableGroupingSeparator="false"
                             AllowMargin="true"
                             AnimationDuration="700"
                             Width="100%"
                             Height="200px">
                <CircularGaugeAxes>
                    <CircularGaugeAxis Minimum="0" Maximum="150" StartAngle="210" EndAngle="150" Radius="80%">
                        <CircularGaugeAxisLineStyle Width="8" Color="#e2e8f0" />
                        <CircularGaugeAxisLabelStyle Format="{value}%">
                            <CircularGaugeAxisLabelFont Size="10px" />
                        </CircularGaugeAxisLabelStyle>
                        <CircularGaugeRanges>
                            <CircularGaugeRange Start="0" End="85" Color="#fca5a5" StartWidth="8" EndWidth="8" />
                            <CircularGaugeRange Start="85" End="100" Color="#fde68a" StartWidth="8" EndWidth="8" />
                            <CircularGaugeRange Start="100" End="150" Color="#6ee7b7" StartWidth="8" EndWidth="8" />
                        </CircularGaugeRanges>
                        <CircularGaugePointers>
                            <CircularGaugePointer Value="@Math.Min(RateAdequacy, 150)" Radius="70%" Color="#0f172a" />
                        </CircularGaugePointers>
                    </CircularGaugeAxis>
                </CircularGaugeAxes>
            </SfCircularGauge>
        </div>
    </div>

    @* ─── RATE COMPARISON BAR CHART ──────────────────────────────────────────── *@
    @if (RateComparison.Count > 0)
    {
        <div id="rate-comparison-section" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="mb-3 text-sm font-semibold text-slate-700">Rate Comparison</p>
            <SfChart ID="budget-variance-chart"
                     AccessibilityDescription="Bar chart showing the rate comparison values used in the executive dashboard."
                     Width="100%"
                     Height="300px"
                     Background="transparent">
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category">
                    <ChartAxisMajorGridLines Width="0" />
                </ChartPrimaryXAxis>
                <ChartPrimaryYAxis LabelFormat="C2">
                    <ChartAxisMajorGridLines DashArray="4,4" Color="#e2e8f0" />
                </ChartPrimaryYAxis>
                <ChartTooltipSettings Enable="true" Header="<b>${point.x}</b>" Format="${point.x}: <b>${point.y}</b>" />
                <ChartLegendSettings Visible="false" />
                <ChartSeriesCollection>
                    <ChartSeries DataSource="@RateComparison"
                                 XName="@nameof(RateComparisonPoint.Label)"
                                 YName="@nameof(RateComparisonPoint.Value)"
                                 Name="Rate"
                                 Type="ChartSeriesType.Column"
                                 Fill="#93c5fd"
                                 ColumnSpacing="0.2">
                        <ChartMarker>
                            <ChartDataLabel Visible="true" Position="LabelPosition.Top" Format="C2">
                                <ChartDataLabelFont Size="10px" />
                            </ChartDataLabel>
                        </ChartMarker>
                    </ChartSeries>
                </ChartSeriesCollection>
            </SfChart>
        </div>
    }

    @* ─── SCENARIO WATERFALL ─────────────────────────────────────────────────── *@
    @if (WaterfallPoints.Count > 1)
    {
        <div id="waterfall-section" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="mb-3 text-sm font-semibold text-slate-700">Scenario Cost Waterfall</p>
            <SfChart ID="scenario-waterfall-chart"
                     AccessibilityDescription="Waterfall chart showing how scenario costs build toward the final rate impact."
                     Width="100%"
                     Height="300px"
                     Background="transparent">
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category">
                    <ChartAxisMajorGridLines Width="0" />
                </ChartPrimaryXAxis>
                <ChartPrimaryYAxis LabelFormat="C0">
                    <ChartAxisMajorGridLines DashArray="4,4" Color="#e2e8f0" />
                </ChartPrimaryYAxis>
                <ChartTooltipSettings Enable="true" Header="<b>${point.x}</b>" />
                <ChartLegendSettings Visible="false" />
                <ChartSeriesCollection>
                    <ChartSeries DataSource="@WaterfallPoints"
                                 XName="@nameof(WaterfallPoint.Label)"
                                 YName="@nameof(WaterfallPoint.Value)"
                                 Name="Cost"
                                 Type="ChartSeriesType.Waterfall"
                                 SumIndexes="@WaterfallSumIndexes"
                                 NegativeFillColor="#fca5a5"
                                 SummaryFillColor="#475569"
                                 Fill="#93c5fd">
                        <ChartMarker>
                            <ChartDataLabel Visible="true" Position="LabelPosition.Top" Format="C0">
                                <ChartDataLabelFont Size="10px" />
                            </ChartDataLabel>
                        </ChartMarker>
                    </ChartSeries>
                </ChartSeriesCollection>
            </SfChart>
        </div>
    }

    @* ─── RATE TREND ─────────────────────────────────────────────────────────── *@
    @if (ProjectionSeries.Count > 0)
    {
        <div id="rate-trend-section" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="mb-3 text-sm font-semibold text-slate-700">Rate Trend &amp; Projection</p>
            <SfChart ID="rate-trend-chart"
                     AccessibilityDescription="Line chart showing the historical and projected rate trend."
                     Width="100%"
                     Height="300px"
                     Background="transparent">
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category">
                    <ChartAxisMajorGridLines Width="0" />
                </ChartPrimaryXAxis>
                <ChartPrimaryYAxis LabelFormat="C2">
                    <ChartAxisMajorGridLines DashArray="4,4" Color="#e2e8f0" />
                </ChartPrimaryYAxis>
                <ChartTooltipSettings Enable="true" Header="<b>Year ${point.x}</b>" />
                <ChartCrosshairSettings Enable="true" LineType="LineType.Both">
                    <ChartCrosshairLine Color="#94a3b8" Width="1" />
                </ChartCrosshairSettings>
                <ChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Top" />
                <ChartSeriesCollection>
                    <ChartSeries DataSource="@ProjectionSeries"
                                 XName="@nameof(ProjectionRow.Year)"
                                 YName="@nameof(ProjectionRow.Rate)"
                                 Name="Projected Rate"
                                 Type="ChartSeriesType.Line"
                                 Fill="#6366f1"
                                 Width="2">
                        <ChartMarker Visible="true" Height="8" Width="8" Fill="#6366f1">
                            <ChartDataLabel Visible="true" Position="LabelPosition.Top" Format="C2">
                                <ChartDataLabelFont Size="10px" />
                            </ChartDataLabel>
                        </ChartMarker>
                    </ChartSeries>
                </ChartSeriesCollection>
            </SfChart>
        </div>
    }

    @* ─── CUSTOMER DISTRIBUTION DONUTS ───────────────────────────────────────── *@
    @if (CustomersByService.Count > 0 || CustomersByCityLimits.Count > 0)
    {
        <div id="customer-donuts-section" class="grid gap-4 md:grid-cols-2">
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm" role="img" aria-label="Customers by service type donut chart">
                <p class="mb-3 text-sm font-semibold text-slate-700">Customers by Service Type</p>
                <SfAccumulationChart ID="customer-service-chart"
                                     EnableAnimation="true"
                                     Background="transparent"
                                     Height="280px">
                    <AccumulationChartTooltipSettings Enable="true" Format="${point.x}: <b>${point.y}</b>" />
                    <AccumulationChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Bottom" />
                    <AccumulationChartSeriesCollection>
                        <AccumulationChartSeries DataSource="@CustomersByService"
                                                 XName="@nameof(PiePoint.Label)"
                                                 YName="@nameof(PiePoint.Count)"
                                                 Name="Service Type"
                                                 InnerRadius="40%"
                                                 Explode="true"
                                                 ExplodeOffset="10%"
                                                 ExplodeIndex="0">
                            <AccumulationDataLabelSettings Visible="true"
                                                           Position="AccumulationLabelPosition.Outside"
                                                           Name="@nameof(PiePoint.Label)">
                                <AccumulationChartDataLabelFont Size="11px" />
                            </AccumulationDataLabelSettings>
                        </AccumulationChartSeries>
                    </AccumulationChartSeriesCollection>
                </SfAccumulationChart>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm" role="img" aria-label="Customers by city limits donut chart">
                <p class="mb-3 text-sm font-semibold text-slate-700">Customers by City Limits</p>
                <SfAccumulationChart ID="customer-citylimits-chart"
                                     EnableAnimation="true"
                                     Background="transparent"
                                     Height="280px">
                    <AccumulationChartTooltipSettings Enable="true" Format="${point.x}: <b>${point.y}</b>" />
                    <AccumulationChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Bottom" />
                    <AccumulationChartSeriesCollection>
                        <AccumulationChartSeries DataSource="@CustomersByCityLimits"
                                                 XName="@nameof(PiePoint.Label)"
                                                 YName="@nameof(PiePoint.Count)"
                                                 Name="City Limits"
                                                 InnerRadius="40%"
                                                 Explode="true"
                                                 ExplodeOffset="10%"
                                                 ExplodeIndex="0">
                            <AccumulationDataLabelSettings Visible="true"
                                                           Position="AccumulationLabelPosition.Outside"
                                                           Name="@nameof(PiePoint.Label)">
                                <AccumulationChartDataLabelFont Size="11px" />
                            </AccumulationDataLabelSettings>
                        </AccumulationChartSeries>
                    </AccumulationChartSeriesCollection>
                </SfAccumulationChart>
            </div>
        </div>
    }
</div>

@code {
    // ── Parameters ────────────────────────────────────────────────────────────
    [Parameter] public decimal CurrentRate { get; set; }
    [Parameter] public decimal TotalCosts { get; set; }
    [Parameter] public decimal ProjectedVolume { get; set; }
    [Parameter] public decimal RecommendedRate { get; set; }
    [Parameter] public decimal AdjustedRecommendedRate { get; set; }
    [Parameter] public decimal ScenarioCostTotal { get; set; }
    [Parameter] public IReadOnlyList<ScenarioItem> ScenarioItems { get; set; } = [];
    [Parameter] public IReadOnlyList<ProjectionRow> ProjectionSeries { get; set; } = [];
    [Parameter] public IReadOnlyList<CustomerRow> Customers { get; set; } = [];
    [Parameter] public IReadOnlyList<RateComparisonPoint> RateComparison { get; set; } = [];
    [Parameter] public string SelectedEnterprise { get; set; } = string.Empty;
    [Parameter] public int SelectedFiscalYear { get; set; }

    // ── Computed KPIs ─────────────────────────────────────────────────────────
    private decimal MonthlyRevenue => CurrentRate * ProjectedVolume;
    private decimal NetPosition    => MonthlyRevenue - TotalCosts;
    private double CoverageRatio   => TotalCosts > 0 ? (double)(MonthlyRevenue / TotalCosts) : 0d;
    private double RateAdequacy    => RecommendedRate > 0 ? (double)(CurrentRate / RecommendedRate * 100m) : 0d;

    // ── Waterfall ─────────────────────────────────────────────────────────────
    private IReadOnlyList<WaterfallPoint> WaterfallPoints
    {
        get
        {
            if (ScenarioItems.Count == 0) return [];
            var pts = new List<WaterfallPoint>();
            pts.Add(new WaterfallPoint("Base Cost", (double)TotalCosts));
            foreach (var item in ScenarioItems)
                pts.Add(new WaterfallPoint(item.Name, (double)item.Cost));
            pts.Add(new WaterfallPoint("With Scenario", 0d));
            return pts;
        }
    }

    private double[] WaterfallSumIndexes => [WaterfallPoints.Count - 1d];

    // ── Customer pies ─────────────────────────────────────────────────────────
    private IReadOnlyList<PiePoint> CustomersByService => Customers
        .Where(c => !string.IsNullOrWhiteSpace(c.Service))
        .GroupBy(c => c.Service)
        .Select(g => new PiePoint(g.Key, g.Count()))
        .OrderByDescending(p => p.Count)
        .ToList();

    private IReadOnlyList<PiePoint> CustomersByCityLimits => Customers
        .Where(c => !string.IsNullOrWhiteSpace(c.CityLimits))
        .GroupBy(c => c.CityLimits)
        .Select(g => new PiePoint(g.Key, g.Count()))
        .OrderByDescending(p => p.Count)
        .ToList();

    // ── Local records ─────────────────────────────────────────────────────────
    private record WaterfallPoint(string Label, double Value);
    private record PiePoint(string Label, int Count);
}
