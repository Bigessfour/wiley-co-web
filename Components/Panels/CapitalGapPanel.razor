@namespace WileyCoWeb.Components.Panels
@using System.Globalization
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Charts
@using Syncfusion.Blazor.Spinner
@using WileyCoWeb.Contracts
@using WileyCoWeb.Services

@inject CapitalGapApiService CapitalGapApiService
@inject ToastService ToastService

<section id="capital-gap-panel" class="space-y-4" aria-live="polite">
    <section class="rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-950 via-slate-900 to-amber-950 p-5 text-white shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300">Capital Gap</p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight">Capital needs versus rate revenue gap analysis</h2>
                <p class="mt-2 max-w-3xl text-sm text-slate-300">Tag capital budget items, compare them to annual rate revenue, and track the cumulative headroom left after each capital commitment.</p>
            </div>
            <div class="grid grid-cols-2 gap-3 text-right text-xs text-slate-300 sm:grid-cols-4 lg:text-sm">
                <div>
                    <div class="text-slate-400">Enterprise</div>
                    <div class="font-semibold text-white">@SelectedEnterprise</div>
                </div>
                <div>
                    <div class="text-slate-400">Fiscal Year</div>
                    <div class="font-semibold text-white">@SelectedFiscalYear</div>
                </div>
                <div>
                    <div class="text-slate-400">Gap Status</div>
                    <div class="font-semibold text-amber-300">@CapitalStatus</div>
                </div>
                <div>
                    <div class="text-slate-400">Capital Items</div>
                    <div class="font-semibold text-white">@CapitalItemCountDisplay</div>
                </div>
            </div>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-col gap-1">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Capital Gap Summary</p>
            <p class="text-sm text-slate-600">Live summary of the capital-tagged budget items against the current rate-revenue base.</p>
        </div>
        <SfCard ID="capital-gap-summary-card" class="mt-3">
            <CardHeader Title="Capital gap summary" SubTitle="@SummarySubtitle" />
            <CardContent Content="@SummaryContent" />
        </SfCard>
    </section>

    @if (IsLoading)
    {
        @* Professional loading state: SfSpinner with skeleton rows replaces the
           plain text fallback. min-height prevents layout shift when data arrives. *@
        <section class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 shadow-sm"
                 style="min-height: 13rem;"
                 aria-busy="true"
                 aria-label="Loading capital gap data">
            <div class="wiley-panel-spinner-host">
                <SfSpinner Visible="true"
                           Label="Loading capital gap data…"
                           Size="36"
                           Type="SpinnerType.Material" />
            </div>
            <div class="px-6 pb-6 space-y-3">
                <div class="wiley-skeleton-row"></div>
                <div class="wiley-skeleton-row"></div>
                <div class="wiley-skeleton-row"></div>
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="rounded-2xl border border-rose-200 bg-rose-50 p-6 text-sm text-rose-900">
            @ErrorMessage
        </section>
    }
    else if (Snapshot is not null)
    {
        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <SfCard ID="capital-gap-kpi-rate-revenue">
                <CardHeader Title="Annual Rate Revenue" SubTitle="Live revenue aggregate" />
                <CardContent Content="@Snapshot.AnnualRateRevenue.ToString("C0")" />
            </SfCard>
            <SfCard ID="capital-gap-kpi-capital-need">
                <CardHeader Title="Annual Capital Need" SubTitle="Tagged capital items" />
                <CardContent Content="@Snapshot.AnnualCapitalNeed.ToString("C0")" />
            </SfCard>
            <SfCard ID="capital-gap-kpi-gap">
                <CardHeader Title="Rate Revenue Gap" SubTitle="Revenue minus capital need" />
                <CardContent Content="@Snapshot.RateRevenueGap.ToString("C0")" />
            </SfCard>
            <SfCard ID="capital-gap-kpi-coverage-ratio">
                <CardHeader Title="Coverage Ratio" SubTitle="Rate revenue / capital need" />
                <CardContent Content="@Snapshot.CapitalNeedCoverageRatio.ToString("0.00x")" />
            </SfCard>
        </section>

        <section class="grid gap-4 xl:grid-cols-[1.25fr_0.95fr]">
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex flex-col gap-1">
                    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Capital Need Chart</p>
                    <p class="text-sm text-slate-600">Stacked budgeted and actual capital amounts with a cumulative revenue-gap line.</p>
                </div>
                <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    @* Theme Fluent2: chart palette aligned with app-wide Syncfusion theme *@
                    @* ChartZoomSettings: capital gap chart is analytical; selection zoom lets councils drill into specific capital items *@
                    <SfChart ID="capital-gap-chart"
                             Title="Capital needs versus rate revenue"
                             AccessibilityDescription="Stacked column chart showing capital needs and actual spend by capital-tagged budget item, with a cumulative revenue gap line."
                             UseGroupingSeparator="true"
                             Width="100%"
                             Height="360px"
                             Theme="Syncfusion.Blazor.Theme.Fluent2">
                        <ChartArea>
                            <ChartAreaBorder Width="0" />
                        </ChartArea>
                        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category" LabelIntersectAction="LabelIntersectAction.Rotate45">
                            <ChartAxisMajorGridLines Width="0" />
                        </ChartPrimaryXAxis>
                        <ChartPrimaryYAxis LabelFormat="C0">
                            <ChartAxisMajorGridLines DashArray="4,4" Color="#e2e8f0" />
                        </ChartPrimaryYAxis>
                        <ChartLegendSettings Visible="true" Position="Syncfusion.Blazor.Charts.LegendPosition.Top" />
                        <ChartZoomSettings EnableSelectionZooming="true" EnableScrollbar="false" />
                        <ChartTooltipSettings Enable="true" Shared="true" Format="${point.x}: ${point.y}" />
                        <ChartSeriesCollection>
                            <ChartSeries DataSource="@CapitalItemsForChart"
                                         XName="Label"
                                         YName="BudgetedAmount"
                                         Name="Budgeted capital"
                                         Type="ChartSeriesType.StackingColumn"
                                         Fill="#0f766e"
                                         ColumnSpacing="0.2" />
                            <ChartSeries DataSource="@CapitalItemsForChart"
                                         XName="Label"
                                         YName="ActualAmount"
                                         Name="Actual spend"
                                         Type="ChartSeriesType.StackingColumn"
                                         Fill="#38bdf8"
                                         ColumnSpacing="0.2" />
                            <ChartSeries DataSource="@CapitalItemsForChart"
                                         XName="Label"
                                         YName="CumulativeGap"
                                         Name="Cumulative gap"
                                         Type="ChartSeriesType.Line"
                                         Fill="#111827"
                                         Width="3">
                                <ChartMarker Visible="true" Width="8" Height="8" Fill="#111827" />
                            </ChartSeries>
                        </ChartSeriesCollection>
                    </SfChart>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex flex-col gap-1">
                    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Capital Tagged Items</p>
                    <p class="text-sm text-slate-600">The same tagged items feed the KPI strip and the cumulative line.</p>
                </div>
                <div id="capital-gap-breakdown" class="mt-3 space-y-3">
                    @foreach (var item in CapitalItemsForChart)
                    {
                        <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-3 shadow-sm">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <div class="flex flex-wrap items-center gap-2">
                                        <div class="text-sm font-semibold text-slate-900">@item.Label</div>
                                        <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-amber-800">@item.Tag</span>
                                    </div>
                                    <div class="mt-1 text-xs text-slate-500">@item.DepartmentName @if (!string.IsNullOrWhiteSpace(item.AccountName)) { <span>• @item.AccountName</span> }</div>
                                </div>
                                <div class="text-right text-xs text-slate-500">
                                    <div class="font-semibold text-slate-700">@item.BudgetedAmount.ToString("C0") budgeted</div>
                                    <div>@item.ActualAmount.ToString("C0") actual</div>
                                    <div class="mt-1 font-semibold text-emerald-700">@item.CumulativeGap.ToString("C0") cumulative gap</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-600">
            Capital gap data is not available yet.
        </section>
    }
</section>

@code {
    [Parameter] public string SelectedEnterprise { get; set; } = string.Empty;
    [Parameter] public int SelectedFiscalYear { get; set; }

    private CapitalGapResponse? Snapshot { get; set; }
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private string? loadedEnterprise;
    private int loadedFiscalYear;

    private string SummarySubtitle => Snapshot is null ? "Awaiting live capital gap data" : $"{Snapshot.SelectedEnterprise} FY {Snapshot.SelectedFiscalYear}";
    private string SummaryContent => Snapshot is null ? "The panel will populate after the workspace loads live rate revenue and capital-tagged budget items." : Snapshot.ExecutiveSummary;
    private string CapitalStatus => Snapshot is null ? "Loading" : Snapshot.CapitalStatus;
    private string CapitalItemCountDisplay => Snapshot?.CapitalItems.Count.ToString("N0") ?? "0";
    private IReadOnlyList<CapitalGapItemPoint> CapitalItemsForChart => Snapshot?.CapitalItems ?? [];

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(SelectedEnterprise) || SelectedFiscalYear <= 0)
        {
            ErrorMessage = "A workspace enterprise and fiscal year are required to load capital gap data.";
            ToastService.ShowWarning("Capital Gap", ErrorMessage);
            Snapshot = null;
            IsLoading = false;
            return;
        }

        if (string.Equals(loadedEnterprise, SelectedEnterprise, StringComparison.OrdinalIgnoreCase) && loadedFiscalYear == SelectedFiscalYear && Snapshot is not null)
        {
            return;
        }

        IsLoading = true;
        ErrorMessage = null;

        try
        {
            Snapshot = await CapitalGapApiService.GetAsync(new CapitalGapRequest(SelectedEnterprise, SelectedFiscalYear));
            loadedEnterprise = Snapshot.SelectedEnterprise;
            loadedFiscalYear = Snapshot.SelectedFiscalYear;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Snapshot = null;
            ToastService.ShowError("Capital Gap failed to load", ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }
}