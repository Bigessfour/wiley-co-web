@page "/"

<PageTitle>Wiley.co</PageTitle>

<section class="home-hub">
	<div class="home-hub-hero">
		<p class="home-hub-kicker">Wiley Widget</p>
		<h1>Rate Study Console</h1>
		<p class="home-hub-copy">
			Start from a focused route instead of loading the full workspace overview on the domain root.
			This keeps the entry screen lighter and makes panel navigation predictable.
		</p>
		<div class="home-hub-actions">
			<a class="home-hub-primary" href="/wiley-workspace">Open workspace overview</a>
			<a class="home-hub-secondary" href="/wiley-workspace/data-dashboard">Open data dashboard</a>
		</div>
	</div>

	<div class="home-hub-grid">
		<a class="home-hub-card" href="/wiley-workspace/break-even">
			<span class="home-hub-card-index">01</span>
			<strong>Break-Even</strong>
			<p>Cost, volume, rate delta, and baseline capture.</p>
		</a>
		<a class="home-hub-card" href="/wiley-workspace/rates">
			<span class="home-hub-card-index">02</span>
			<strong>Rates</strong>
			<p>Current-rate editing and comparison chart review.</p>
		</a>
		<a class="home-hub-card" href="/wiley-workspace/scenario">
			<span class="home-hub-card-index">03</span>
			<strong>Scenario Planner</strong>
			<p>What-if modeling and adjusted break-even analysis.</p>
		</a>
		<a class="home-hub-card" href="/wiley-workspace/customers">
			<span class="home-hub-card-index">04</span>
			<strong>Customer Viewer</strong>
			<p>Filtered customer review and export-ready exploration.</p>
		</a>
		<a class="home-hub-card" href="/wiley-workspace/trends">
			<span class="home-hub-card-index">05</span>
			<strong>Trends</strong>
			<p>Projected rate movement and year-over-year view.</p>
		</a>
		<a class="home-hub-card" href="/wiley-workspace/decision-support">
			<span class="home-hub-card-index">06</span>
			<strong>Decision Support</strong>
			<p>Jarvis guidance and supporting analysis context.</p>
		</a>
	</div>
</section>
