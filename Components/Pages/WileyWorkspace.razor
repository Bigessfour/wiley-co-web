@code {
    private SfSplitter? _workspaceSplitter;

    /// <summary>
    /// Expands or collapses the Jarvis AI chat pane (pane 2) in the SfSplitter
    /// and keeps <see cref="WorkspaceLayoutContext.IsJarvisOpen"/> in sync via
    /// the layout context so every subscriber observes the change.
    /// </summary>
    private async Task ToggleJarvisAsync()
    {
        // ToggleJarvis() calls LayoutContext.SetJarvisOpen(!current) which fires
        // OnChange — any subscriber (e.g. a decision-support badge) re-renders.
        ToggleJarvis();

        if (IsJarvisOpen)
            await (_workspaceSplitter?.ExpandAsync(2) ?? Task.CompletedTask);
        else
            await (_workspaceSplitter?.CollapseAsync(2) ?? Task.CompletedTask);
    }

    /// <summary>
    /// Called by <c>SplitterEvents.Collapsed</c>. Notifies the layout context
    /// so <see cref="WorkspaceLayoutContext.IsJarvisOpen"/> and
    /// <see cref="WorkspaceLayoutContext.IsContextRailCollapsed"/> stay in sync
    /// with the actual splitter state.
    /// </summary>
    private void HandleSplitterCollapsed(Syncfusion.Blazor.Layouts.ExpandedEventArgs args)
    {
        if (args.Index.Contains(2) && IsJarvisOpen)
        {
            // Jarvis pane was closed externally (drag handle) — sync the context.
            LayoutContext?.SetJarvisOpen(false);
            StateHasChanged();
        }

        if (args.Index.Contains(0) && !IsContextRailCollapsed)
        {
            // Context rail pane was collapsed — notify the context so panels can
            // adapt their widths (e.g. chart containers relayout).
            NotifyContextRailCollapsed();
            StateHasChanged();
        }
    }

    /// <summary>
    /// Called by <c>SplitterEvents.Expanded</c>. Mirrors the splitter state
    /// back into the layout context.
    /// </summary>
    private void HandleSplitterExpanded(Syncfusion.Blazor.Layouts.ExpandedEventArgs args)
    {
        if (args.Index.Contains(2) && !IsJarvisOpen)
        {
            LayoutContext?.SetJarvisOpen(true);
            StateHasChanged();
        }

        if (args.Index.Contains(0) && IsContextRailCollapsed)
        {
            NotifyContextRailExpanded();
            StateHasChanged();
        }
    }
}
