                    </ContentTemplate>
                </SplitterPane>
            </SplitterPanes>
        </SfSplitter>

        @if (!string.Equals(ActivePanelKey, "decision-support", StringComparison.Ordinal) && !IsJarvisOpen)
        {
            <SfButton id="workspace-jarvis-launcher"
