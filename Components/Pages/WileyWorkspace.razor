@page "/wiley-workspace"
@page "/wiley-workspace/{Panel?}"

@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Layouts
@using WileyCoWeb.Components.Panels
@using WileyCoWeb.Contracts
@using WileyCoWeb.State

@inherits WileyWorkspaceBase

<PageTitle>Wiley Workspace | Wiley.co</PageTitle>

<div class="wiley-workspace min-h-screen bg-slate-50 px-4 py-4 md:px-6 lg:px-8">
    <div class="mx-auto flex max-w-[96rem] flex-col gap-4">
        <div class="rounded-3xl border border-slate-200 bg-gradient-to-r from-slate-950 via-slate-900 to-sky-950 px-6 py-5 text-white shadow-lg">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-sky-300">Wiley Widget</p>
                    <h1 class="mt-2 text-2xl font-semibold tracking-tight md:text-3xl">Utility Rate Study Workspace</h1>
                    <p class="mt-2 max-w-3xl text-sm text-slate-300 md:text-base">
                        Focused enterprise analysis for break-even rates, scenarios, customer review, and AI guidance.
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-3 text-right text-xs text-slate-300 sm:grid-cols-4 lg:text-sm">
                    <div>
                        <div class="text-slate-400">Enterprise</div>
                        <div class="font-semibold text-white">@SelectedEnterprise</div>
                    </div>
                    <div>
                        <div class="text-slate-400">Fiscal Year</div>
                        <div class="font-semibold text-white">@SelectedFiscalYear</div>
                    </div>
                    <div>
                        <div class="text-slate-400">Current Rate</div>
                        <div class="font-semibold text-white">@CurrentRateDisplay</div>
                    </div>
                    <div>
                        <div class="text-slate-400">Break-Even</div>
                        <div class="font-semibold text-emerald-300">@BreakEvenRateDisplay</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Document Center</p>
                    <h2 class="mt-1 text-lg font-semibold text-slate-900">Syncfusion Excel & PDF Deliverables</h2>
                    <p class="mt-1 text-sm text-slate-600">Export the filtered customer set, the active scenario workbook, or a PDF rate packet from the current workspace state.</p>
                </div>
                <div class="flex flex-col gap-3 xl:min-w-[38rem]">
                    <div class="grid gap-3 md:grid-cols-3">
                        <SfButton id="export-customers-excel-button" CssClass="e-primary" IsPrimary="true" Disabled="@IsExportingDocuments" OnClick="ExportCustomerWorkbookAsync">Export customers to Excel</SfButton>
                        <SfButton id="export-scenario-excel-button" Disabled="@IsExportingDocuments" OnClick="ExportScenarioWorkbookAsync">Export scenario to Excel</SfButton>
                        <SfButton id="export-workspace-pdf-button" Disabled="@IsExportingDocuments" OnClick="ExportWorkspacePdfAsync">Download PDF rate packet</SfButton>
                    </div>
                    <div class="rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-600">
                        <span class="font-semibold text-slate-700">Export status:</span> @DocumentExportStatus
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:hidden">
            <SfButton CssClass="e-outline" OnClick="ToggleSidebar">@(IsSidebarOpen ? "Hide workspace controls" : "Show workspace controls")</SfButton>
        </div>

        <div class="flex flex-col gap-4 lg:flex-row">
            <aside class="workspace-sidebar @(IsSidebarOpen ? "block" : "hidden") lg:block lg:w-[22rem] lg:shrink-0">
                <div class="space-y-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                    <SfCard>
                        <CardHeader Title="Enterprise Context" SubTitle="Select the active service and fiscal year" />
                        <CardContent>
                            <div class="space-y-4">
                                <SfDropDownList TValue="string" TItem="string" DataSource="@EnterpriseOptions" Value="@SelectedEnterprise" ValueChange="HandleEnterpriseChanged" Placeholder="Enterprise" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" ShowClearButton="true" PopupHeight="240px" Width="100%" />
                                <SfDropDownList TValue="int" TItem="int" DataSource="@FiscalYearOptions" Value="@SelectedFiscalYear" ValueChange="HandleFiscalYearChanged" Placeholder="Fiscal Year" FloatLabelType="FloatLabelType.Auto" PopupHeight="240px" Width="100%" />
                                <SfTextBox ID="scenario-name-input" Placeholder="Scenario name" FloatLabelType="FloatLabelType.Auto" ShowClearButton="true" Width="100%" @bind-Value="ActiveScenarioName" />
                                <SfTextBox Placeholder="Scenario description" FloatLabelType="FloatLabelType.Auto" Multiline="true" Rows="3" ShowClearButton="true" Width="100%" @bind-Value="ScenarioDescription" />
                                <SfDropDownList TValue="long?" TItem="WorkspaceScenarioSummaryResponse" DataSource="@SavedScenarios" Value="@SelectedScenarioSnapshotId" ValueChange="HandleSavedScenarioChanged" Placeholder="Saved scenarios" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" ShowClearButton="true" PopupHeight="280px" Width="100%">
                                    <DropDownListFieldSettings Text="ScenarioName" Value="SnapshotId" />
                                </SfDropDownList>
                            </div>
                        </CardContent>
                    </SfCard>

                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Hosting Information</p>
                        <div class="mt-3 grid gap-2 text-xs text-slate-600">
                            <div><span class="font-semibold text-slate-700">Environment:</span> @HostingEnvironmentName</div>
                            <div><span class="font-semibold text-slate-700">Last synced:</span> @HostingLastSyncedDisplay</div>
                            <div><span class="font-semibold text-slate-700">Persistence:</span> @HostingPersistenceStatus</div>
                            <div><span class="font-semibold text-slate-700">API health:</span> @HostingApiHealth</div>
                            <div><span class="font-semibold text-slate-700">Version:</span> @HostingVersion</div>
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Workspace Navigation</p>
                        <div class="mt-2 grid gap-2">
                            @foreach (var panelNavItem in PanelNavItems)
                            {
                                <SfButton CssClass="@(ActivePanelKey == panelNavItem.Key ? "e-primary" : string.Empty)"
                                          IsPrimary="@(ActivePanelKey == panelNavItem.Key)"
                                          OnClick="() => OpenPanel(panelNavItem.Key)">
                                    @panelNavItem.Label
                                </SfButton>
                            }
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Global Actions</p>
                        <div class="mt-2 grid gap-2">
                            <SfButton Disabled="@IsLoadingWorkspace" OnClick="RefreshWorkspaceAsync">@(IsLoadingWorkspace ? "Refreshing..." : "Reload workspace")</SfButton>
                            <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsSavingBaseline" OnClick="SaveWorkspaceBaselineAsync">@(IsSavingBaseline ? "Saving baseline..." : "Save baseline")</SfButton>
                            <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsSavingScenario" OnClick="SaveScenarioAsync">@(IsSavingScenario ? "Saving..." : "Save scenario")</SfButton>
                            <SfButton Disabled="@(!CanApplySelectedScenario || IsApplyingScenario)" OnClick="ApplySelectedScenarioAsync">@(IsApplyingScenario ? "Applying..." : "Apply saved scenario")</SfButton>
                            <div class="grid grid-cols-1 gap-2 pt-2">
                                <SfButton Disabled="@IsExportingDocuments" OnClick="ExportCustomerWorkbookAsync">Export customers</SfButton>
                                <SfButton Disabled="@IsExportingDocuments" OnClick="ExportScenarioWorkbookAsync">Export scenario</SfButton>
                                <SfButton Disabled="@IsExportingDocuments" OnClick="ExportWorkspacePdfAsync">Export PDF packet</SfButton>
                            </div>
                        </div>
                    </div>

                    <div class="rounded-xl bg-slate-50 px-3 py-3 text-xs text-slate-600">
                        <div id="workspace-load-status"><span class="font-semibold text-slate-700">Workspace:</span> @WorkspaceLoadStatus</div>
                        <div class="mt-2"><span class="font-semibold text-slate-700">Scenarios:</span> <span id="scenario-persistence-status">@ScenarioPersistenceStatus</span></div>
                        <div class="mt-2">
                            <span class="font-semibold text-slate-700">Startup source:</span>
                            <span class="@(IsUsingStartupFallback ? "text-amber-700" : "text-emerald-700")"> @StartupSourceStatus</span>
                        </div>
                        <div class="mt-2">
                            <span class="font-semibold text-slate-700">Current state:</span>
                            <span class="@(IsUsingBrowserRestoredState ? "text-sky-700" : "text-emerald-700")"> @CurrentStateSourceStatus</span>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="min-w-0 flex-1 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm md:p-5">
                <div class="mb-4 border-b border-slate-200 pb-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">@BreadcrumbSection</p>
                    <div class="mt-1 flex items-center gap-2 text-sm text-slate-500">
                        <span>Workspace</span>
                        <span>/</span>
                        <span class="font-semibold text-slate-800">@ActivePanelLabel</span>
                    </div>
                </div>

                @if (IsOverviewMode)
                {
                    <SfDashboardLayout ID="workspace-overview-dashboard"
                                       Columns="6"
                                       CellSpacing="@(new double[] { 16, 16 })"
                                       AllowDragging="false"
                                       AllowResizing="false"
                                       EnablePersistence="false"
                                       MediaQuery="(max-width: 1200px)"
                                       ShowGridLines="false">
                        <DashboardLayoutPanels>
                            <DashboardLayoutPanel Id="overview-break-even" Row="0" Column="0" SizeX="3" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Break-Even</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">Current @CurrentRateDisplay · Recommended @BreakEvenRateDisplay · Delta @RateDeltaDisplay</p>
                                    <div class="mt-3"><SfButton CssClass="e-primary" IsPrimary="true" OnClick='() => OpenPanel("break-even")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-rates" Row="0" Column="3" SizeX="3" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Rates</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">Rate editing, comparison chart, and snapshot persistence.</p>
                                    <div class="mt-3"><SfButton CssClass="e-primary" IsPrimary="true" OnClick='() => OpenPanel("rates")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-import" Row="1" Column="0" SizeX="2" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">QuickBooks Import</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">Upload and validate QuickBooks records before commit.</p>
                                    <div class="mt-3"><SfButton OnClick='() => OpenPanel("quickbooks-import")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-scenario" Row="1" Column="2" SizeX="2" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Scenario Planner</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">Build what-if cost changes and compare adjusted break-even.</p>
                                    <div class="mt-3"><SfButton OnClick='() => OpenPanel("scenario")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-customers" Row="1" Column="4" SizeX="2" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Customer Viewer</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">@FilteredCustomerCountDisplay customers match active filters.</p>
                                    <div class="mt-3"><SfButton OnClick='() => OpenPanel("customers")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-trends" Row="2" Column="0" SizeX="3" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Trends & Projections</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">Historical and projected rate trend line by year.</p>
                                    <div class="mt-3"><SfButton OnClick='() => OpenPanel("trends")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-ai" Row="2" Column="3" SizeX="3" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Decision Support</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">Context-aware Jarvis recommendations for operational and rate decisions.</p>
                                    <div class="mt-3"><SfButton OnClick='() => OpenPanel("decision-support")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                            <DashboardLayoutPanel Id="overview-data-dashboard" Row="3" Column="0" SizeX="6" SizeY="1">
                                <HeaderTemplate><h3 class="text-base font-semibold text-slate-900">Data Dashboard</h3></HeaderTemplate>
                                <ContentTemplate>
                                    <p class="text-sm text-slate-600">KPI gauges, coverage ratio, rate adequacy, scenario waterfall, rate trend, and customer distribution.</p>
                                    <div class="mt-3"><SfButton CssClass="e-primary" IsPrimary="true" OnClick='() => OpenPanel("data-dashboard")'>Open full view</SfButton></div>
                                </ContentTemplate>
                            </DashboardLayoutPanel>
                        </DashboardLayoutPanels>
                    </SfDashboardLayout>
                }
                else
                {
                    @switch (ActivePanelKey)
                    {
                        case "break-even":
                            <BreakEvenPanel @key="ActivePanelKey"
                                            TotalCosts="@TotalCosts"
                                            ProjectedVolume="@ProjectedVolume"
                                            TotalCostsDisplay="@TotalCostsDisplay"
                                            ProjectedVolumeDisplay="@ProjectedVolumeDisplay"
                                            RateDeltaDisplay="@RateDeltaDisplay"
                                            BreakEvenRateDisplay="@BreakEvenRateDisplay"
                                            IsSavingBaseline="@IsSavingBaseline"
                                            BaselineSaveStatus="@BaselineSaveStatus"
                                            GaugeMaximum="@GaugeMaximum"
                                            GaugeCurrentRateValue="@GaugeCurrentRateValue"
                                            RateComparison="@RateComparison"
                                            OnTotalCostsChanged="HandleTotalCostsChanged"
                                            OnProjectedVolumeChanged="HandleProjectedVolumeChanged"
                                            OnSaveWorkspaceBaseline="SaveWorkspaceBaselineAsync" />
                            break;
                        case "rates":
                            <RatesPanel @key="ActivePanelKey"
                                        CurrentRate="@CurrentRate"
                                        CurrentRateDisplay="@CurrentRateDisplay"
                                        BreakEvenRateDisplay="@BreakEvenRateDisplay"
                                        IsSavingSnapshot="@IsSavingSnapshot"
                                        SnapshotSaveStatus="@SnapshotSaveStatus"
                                        RateComparison="@RateComparison"
                                        OnCurrentRateChanged="HandleCurrentRateChanged"
                                        OnSaveRateSnapshot="SaveRateSnapshotAsync" />
                            break;
                        case "quickbooks-import":
                            <QuickBooksImportPanelWrapper @key="ActivePanelKey" WorkspaceState="@WorkspaceState" />
                            break;
                        case "scenario":
                            <ScenarioPlannerPanel @key="ActivePanelKey"
                                                  ScenarioAdjustedRate="@ScenarioAdjustedRate"
                                                  ScenarioCostTotal="@ScenarioCostTotal"
                                                  ScenarioAdjustedDelta="@ScenarioAdjustedDelta"
                                                  CurrentRate="@CurrentRate"
                                                  BreakEvenRateDisplay="@BreakEvenRateDisplay"
                                                  ScenarioAdjustedRateDisplay="@ScenarioAdjustedRateDisplay"
                                                  ScenarioCostTotalDisplay="@ScenarioCostTotalDisplay"
                                                  ScenarioAdjustedDeltaDisplay="@ScenarioAdjustedDeltaDisplay"
                                                  ScenarioItems="@ScenarioItems"
                                                  ScenarioToolbarItems="@ScenarioToolbarItems"
                                                  OnScenarioGridActionComplete="HandleScenarioGridActionComplete" />
                            break;
                        case "customers":
                            <CustomerViewerPanel @key="ActivePanelKey"
                                                 FilteredCustomerCountDisplay="@FilteredCustomerCountDisplay"
                                                 SelectedCustomerService="@SelectedCustomerService"
                                                 SelectedCustomerCityLimits="@SelectedCustomerCityLimits"
                                                 CustomerSearchTerm="@CustomerSearchTerm"
                                                 CustomerSearchTermChanged="@(value => CustomerSearchTerm = value)"
                                                 CustomerServiceOptions="@CustomerServiceOptions"
                                                 CustomerCityLimitOptions="@CustomerCityLimitOptions"
                                                 SelectedCustomerServiceChanged="@(value => SelectedCustomerService = value)"
                                                 SelectedCustomerCityLimitsChanged="@(value => SelectedCustomerCityLimits = value)"
                                                 Customers="@Customers"
                                                 OnClearCustomerFilters="ClearCustomerFilters" />
                            break;
                        case "trends":
                            <TrendsPanel @key="ActivePanelKey" ProjectionSeries="@ProjectionSeries" />
                            break;
                        case "decision-support":
                            <DecisionSupportPanel @key="ActivePanelKey" />
                            break;
                        case "data-dashboard":
                            <DataDashboardPanel @key="ActivePanelKey"
                                                CurrentRate="@CurrentRate"
                                                TotalCosts="@TotalCosts"
                                                ProjectedVolume="@ProjectedVolume"
                                                RecommendedRate="@RecommendedRate"
                                                AdjustedRecommendedRate="@ScenarioAdjustedRate"
                                                ScenarioCostTotal="@ScenarioCostTotal"
                                                ScenarioItems="@ScenarioItems"
                                                ProjectionSeries="@ProjectionSeries"
                                                Customers="@Customers"
                                                RateComparison="@RateComparison"
                                                SelectedEnterprise="@SelectedEnterprise"
                                                SelectedFiscalYear="@SelectedFiscalYear" />
                            break;
                        default:
                            NavigationManager.NavigateTo("/wiley-workspace", replace: true);
                            break;
                    }
                }
            </main>
        </div>
    </div>
</div>

<style>
    .wiley-workspace .workspace-sidebar {
        max-height: calc(100vh - 14rem);
        overflow: auto;
    }

    .wiley-workspace .e-dashboardlayout {
        background: transparent;
        border: 0;
    }

    .wiley-workspace .e-panel {
        border-radius: 1.25rem;
        overflow: hidden;
    }

    .wiley-workspace .e-panel-header {
        border-bottom: 1px solid rgba(148, 163, 184, 0.22);
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.95), rgba(255, 255, 255, 0.92));
        padding: 1rem 1.125rem;
    }

    .wiley-workspace .e-panel-content {
        background: transparent;
        padding: 1rem 1.125rem 1.125rem;
    }

    .wiley-workspace .e-card {
        height: 100%;
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 1rem;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    @@media (max-width: 1024px) {
        .wiley-workspace .workspace-sidebar {
            max-height: none;
        }
    }
</style>
