@page "/wiley-workspace"
@page "/wiley-workspace/{Panel?}"

@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Layouts
@using Syncfusion.Blazor.Spinner
@using WileyCoWeb.Components.Panels
@using WileyCoWeb.Contracts
@using WileyCoWeb.State

@inherits WileyWorkspaceBase

<PageTitle>Wiley Workspace | Wiley.co</PageTitle>

<LoggingErrorBoundary BoundaryName="WileyWorkspace">
    <ChildContent>
<div class="wiley-workspace min-h-screen bg-slate-50 px-4 py-4 md:px-6 lg:px-8">
    <div class="flex w-full flex-col gap-4">
        <div id="workspace-overview-hero" class="rounded-3xl border border-slate-200 bg-gradient-to-r from-slate-950 via-slate-900 to-sky-950 px-6 py-5 text-white shadow-lg">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-sky-300">Wiley Widget</p>
                    <h1 class="mt-2 text-2xl font-semibold tracking-tight md:text-3xl">Utility Rate Study Workspace</h1>
                    <p class="mt-2 max-w-3xl text-sm text-slate-300 md:text-base">
                        Focused enterprise analysis for break-even rates, scenarios, customer review, and AI guidance.
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-3 text-right text-xs text-slate-300 sm:grid-cols-4 lg:text-sm">
                    <div>
                        <div class="text-slate-400">Selected enterprise</div>
                        <div class="font-semibold text-white">@SelectedEnterprise</div>
                    </div>
                    <div>
                        <div class="text-slate-400">Fiscal Year</div>
                        <div class="font-semibold text-white">@SelectedFiscalYear</div>
                    </div>
                    <div>
                        <div class="text-slate-400">Current Rate</div>
                        <div class="font-semibold text-white">@CurrentRateDisplay</div>
                    </div>
                    <div>
                        <div class="text-slate-400">Break-Even</div>
                        <div class="font-semibold text-emerald-300">@BreakEvenRateDisplay</div>
                    </div>
                    <div class="col-span-2 sm:col-span-4 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-left">
                        <div class="text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-sky-200">Four-enterprise break-even points</div>
                        <div class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                            @foreach (var quadrant in HeroBreakEvenQuadrants)
                            {
                                <div class="rounded-xl border border-white/10 bg-slate-950/40 px-3 py-2">
                                    <div class="text-sm font-semibold text-white">@GetHeroBreakEvenLabel(quadrant)</div>
                                    <div class="mt-1 text-xs text-slate-300">Break-even</div>
                                    <div class="text-lg font-semibold text-emerald-300">@quadrant.BreakEvenRate.ToString("C2")</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="workspace-document-center" class="rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Document Center</p>
                    <h2 class="mt-1 text-lg font-semibold text-slate-900">Syncfusion Excel & PDF Deliverables</h2>
                    <p class="mt-1 text-sm text-slate-600">Export the filtered customer set, the active scenario workbook, or a PDF rate packet from the current workspace state.</p>
                </div>
                <div class="flex flex-col gap-3 xl:min-w-[38rem]">
                    <div class="grid gap-3 md:grid-cols-3">
                        @* Export buttons disable during any export operation so concurrent file-writes are prevented *@
                        <SfButton id="export-customers-excel-button"
                                  CssClass="e-primary"
                                  IsPrimary="true"
                                  Disabled="@IsExportingDocuments"
                                  IconCss="@(IsExportingDocuments ? "" : "e-icons e-export-excel")"
                                  OnClick="ExportCustomerWorkbookAsync">
                            @(IsExportingDocuments ? "Exporting…" : "Export customers to Excel")
                        </SfButton>
                        <SfButton id="export-scenario-excel-button"
                                  Disabled="@IsExportingDocuments"
                                  IconCss="@(IsExportingDocuments ? "" : "e-icons e-export-excel")"
                                  OnClick="ExportScenarioWorkbookAsync">
                            @(IsExportingDocuments ? "Exporting…" : "Export scenario to Excel")
                        </SfButton>
                        <SfButton id="export-workspace-pdf-button"
                                  Disabled="@IsExportingDocuments"
                                  IconCss="@(IsExportingDocuments ? "" : "e-icons e-pdf")"
                                  OnClick="ExportWorkspacePdfAsync">
                            @(IsExportingDocuments ? "Building PDF…" : "Download PDF rate packet")
                        </SfButton>
                    </div>
                    @* Export status row: shows inline spinner dot while export is in-flight *@
                    <div class="rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-600">
                        @if (IsExportingDocuments)
                        {
                            <span class="wiley-export-spinner-inline">
                                <span class="wiley-pulse-dot" aria-hidden="true"></span>
                                <span role="status" aria-live="polite"><span class="font-semibold text-slate-700">Export status:</span> @DocumentExportStatus</span>
                            </span>
                        }
                        else
                        {
                            <span role="status"><span class="font-semibold text-slate-700">Export status:</span> @DocumentExportStatus</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <SfSplitter @ref="_workspaceSplitter"
                    ID="workspace-main-splitter"
                    Height="calc(100vh - 20rem)"
                    Width="100%"
                    EnablePersistence="true"
                    CssClass="workspace-splitter">
            <SplitterEvents Collapsed="HandleSplitterCollapsed" Expanded="HandleSplitterExpanded" />
            <SplitterPanes>
                @* Context Rail – pane 0: enterprise context, navigation, actions *@
                <SplitterPane Size="280px" Min="48px" Max="420px" Resizable="true" Collapsible="true">
                    <ContentTemplate>
                        <div id="workspace-sidebar-shell" class="workspace-pane-context-rail h-full overflow-y-auto overflow-x-hidden space-y-4 p-4">
                    <SfCard ID="workspace-enterprise-context-card">
                            <CardHeader Title="Enterprise Context" SubTitle="Select the active service and fiscal year" />
                            <CardContent>
                                <div class="space-y-4">
                                    @* EnablePersistence: restores the selected enterprise across page refreshes so users return to their active workspace context *@
                                    <SfDropDownList ID="enterprise-select" TValue="string" TItem="string" DataSource="@EnterpriseOptions" Value="@SelectedEnterprise" Placeholder="Enterprise" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" ShowClearButton="true" PopupHeight="240px" Width="100%" FilterBarPlaceholder="Search enterprises..." EnablePersistence="true" PersistenceKey="wiley.workspace.enterprise.v1">
                                        <DropDownListEvents TValue="string" TItem="string" ValueChange="HandleEnterpriseChanged" />
                                    </SfDropDownList>
                                    @* EnablePersistence: preserves the selected fiscal year as part of the user's active workspace context *@
                                    <SfDropDownList ID="fiscal-year-select" TValue="int" TItem="int" DataSource="@FiscalYearOptions" Value="@SelectedFiscalYear" Placeholder="Fiscal Year" FloatLabelType="FloatLabelType.Auto" PopupHeight="240px" Width="100%" EnablePersistence="true" PersistenceKey="wiley.workspace.fiscal-year.v1">
                                        <DropDownListEvents TValue="int" TItem="int" ValueChange="HandleFiscalYearChanged" />
                                    </SfDropDownList>
                                    @* MaxLength: prevents runaway scenario names from exceeding the Aurora column width *@
                                    <SfTextBox ID="scenario-name-input" Placeholder="Scenario name" FloatLabelType="FloatLabelType.Auto" ShowClearButton="true" Width="100%" @bind-Value="ActiveScenarioName" MaxLength="128" />
                                    @* MaxLength: caps description length in line with Aurora varchar column size *@
                                    <SfTextBox ID="scenario-description-input" Placeholder="Scenario description" FloatLabelType="FloatLabelType.Auto" Multiline="true" Rows="3" ShowClearButton="true" Width="100%" @bind-Value="ScenarioDescription" MaxLength="512" />
                                    @* EnableVirtualization: scenarios grow unbounded; virtualization keeps the popup responsive at scale *@
                                    @* EnablePersistence: restores the last-applied scenario selection across page refreshes *@
                                    <SfDropDownList ID="saved-scenarios-dropdown" TValue="long?" TItem="WorkspaceScenarioSummaryResponse" DataSource="@SavedScenarios" Value="@SelectedScenarioSnapshotId" Placeholder="Saved scenarios" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" ShowClearButton="true" PopupHeight="280px" Width="100%" EnableVirtualization="true" FilterBarPlaceholder="Search scenarios..." EnablePersistence="true" PersistenceKey="wiley.workspace.scenario.v1">
                                        <DropDownListFieldSettings Text="ScenarioName" Value="SnapshotId" />
                                        <DropDownListEvents TValue="long?" TItem="WorkspaceScenarioSummaryResponse" ValueChange="HandleSavedScenarioChanged" />
                                    </SfDropDownList>
                                </div>
                            </CardContent>
                        </SfCard>

                        <div id="workspace-hosting-information" class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Hosting Information</p>
                            <div class="mt-3 grid gap-2 text-xs text-slate-600">
                                <div><span class="font-semibold text-slate-700">Environment:</span> @HostingEnvironmentName</div>
                                <div><span class="font-semibold text-slate-700">Last synced:</span> @HostingLastSyncedDisplay</div>
                                <div><span class="font-semibold text-slate-700">Persistence:</span> @HostingPersistenceStatus</div>
                                <div><span class="font-semibold text-slate-700">API health:</span> @HostingApiHealth</div>
                                <div><span class="font-semibold text-slate-700">Version:</span> @HostingVersion</div>
                            </div>
                        </div>

                        <div id="workspace-navigation-card" class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Workspace Navigation</p>
                            <div id="workspace-navigation-list" class="mt-2 grid gap-2">
                                @foreach (var panelNavItem in PanelNavItems)
                                {
                                    <a href="@GetPanelRoute(panelNavItem.Key)"
                                       class="workspace-panel-link block w-full text-left px-3 py-2 rounded-lg text-sm transition-colors @(ActivePanelKey == panelNavItem.Key ? "bg-sky-100 text-sky-900 font-semibold border-sky-200" : "text-slate-600 hover:bg-slate-100")"
                                       @onclick="() => OpenPanel(panelNavItem.Key)"
                                       @onclick:preventDefault>
                                        @panelNavItem.Label
                                    </a>
                                }
                            </div>
                        </div>

                        <div id="workspace-global-actions-card" class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Global Actions</p>
                            <div class="mt-2 grid gap-2">
                                <SfButton Disabled="@IsLoadingWorkspace" OnClick="RefreshWorkspaceAsync">@(IsLoadingWorkspace ? "Refreshing..." : "Reload workspace")</SfButton>
                                <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsSavingBaseline" OnClick="SaveWorkspaceBaselineAsync">@(IsSavingBaseline ? "Saving baseline..." : "Save baseline")</SfButton>
                                <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsSavingScenario" OnClick="SaveScenarioAsync">@(IsSavingScenario ? "Saving..." : "Save scenario")</SfButton>
                                <SfButton Disabled="@(!CanApplySelectedScenario || IsApplyingScenario)" OnClick="ApplySelectedScenarioAsync">@(IsApplyingScenario ? "Applying..." : "Apply saved scenario")</SfButton>
                                <div class="grid grid-cols-1 gap-2 pt-2">
                                    <SfButton Disabled="@IsExportingDocuments" OnClick="ExportCustomerWorkbookAsync">Export customers</SfButton>
                                    <SfButton Disabled="@IsExportingDocuments" OnClick="ExportScenarioWorkbookAsync">Export scenario</SfButton>
                                    <SfButton Disabled="@IsExportingDocuments" OnClick="ExportWorkspacePdfAsync">Export PDF packet</SfButton>
                                </div>
                            </div>
                        </div>

                        <div id="workspace-status-card" class="rounded-xl bg-slate-50 px-3 py-3 text-xs text-slate-600">
                            <div id="workspace-load-status"><span class="font-semibold text-slate-700">Workspace:</span> @WorkspaceLoadStatus</div>
                            <div class="mt-2"><span class="font-semibold text-slate-700">Scenarios:</span> <span id="scenario-persistence-status">@ScenarioPersistenceStatus</span></div>
                            <div class="mt-2">
                                <span class="font-semibold text-slate-700">Startup source:</span>
                                <span class="@(IsUsingStartupFallback ? "text-amber-700" : "text-emerald-700")"> @StartupSourceStatus</span>
                            </div>
                            <div class="mt-2">
                                <span class="font-semibold text-slate-700">Current state:</span>
                                <span class="@(IsUsingBrowserRestoredState ? "text-sky-700" : "text-emerald-700")"> @CurrentStateSourceStatus</span>
                            </div>
                        </div>
                        </div>
                    </ContentTemplate>
                </SplitterPane>

                @* Main Content – pane 1: active panel router *@
                <SplitterPane Min="420px" Resizable="true" Collapsible="false">
                    <ContentTemplate>
                        <div id="workspace-main-content" class="workspace-pane-main h-full overflow-y-auto overflow-x-hidden">
                        <div id="workspace-dashboard" class="w-full">
                    <div class="workspace-main-shell flex flex-col gap-4 p-4 md:p-5">
                        <div id="workspace-breadcrumb" class="border-b border-slate-200 pb-3">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">@BreadcrumbSection</p>
                            <div class="mt-1 flex items-center gap-2 text-sm text-slate-500">
                                <span>Workspace</span>
                                <span>/</span>
                                <span class="font-semibold text-slate-800">@ActivePanelLabel</span>
                            </div>
                        </div>

                        @* ── Workspace initialization skeleton ──────────────────────────────
                           Renders while the first-render persistence cycle is in-flight so the
                           user never sees a jarring blank canvas.  Replaced by real content as
                           soon as IsInitializingWorkspace flips false in OnAfterRenderAsync.
                           ──────────────────────────────────────────────────────────────────── *@
                        @if (IsInitializingWorkspace)
                        {
                            <div id="workspace-init-skeleton" aria-busy="true" aria-label="Workspace initializing" class="space-y-4">
                                @* Spinner row with descriptive label *@
                                <div class="flex items-center gap-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-5">
                                    <div class="wiley-panel-spinner-host" style="min-height:3.5rem; width:3.5rem;">
                                        <SfSpinner Visible="true" Size="32" Type="SpinnerType.Material" />
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-slate-700">Initializing workspace…</p>
                                        <p class="mt-0.5 text-xs text-slate-500">Restoring saved selections and connecting to live data.</p>
                                    </div>
                                </div>
                                @* Skeleton overview card grid *@
                                <div class="wiley-overview-skeleton-grid">
                                    @for (int i = 0; i < 8; i++)
                                    {
                                        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm space-y-3">
                                            <div class="wiley-skeleton h-3 w-1/3 rounded"></div>
                                            <div class="wiley-skeleton h-5 w-2/3 rounded"></div>
                                            <div class="wiley-skeleton h-3 w-full rounded"></div>
                                            <div class="wiley-skeleton h-3 w-5/6 rounded"></div>
                                            <div class="mt-4 wiley-skeleton h-8 w-1/2 rounded-lg"></div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        @* ── Workspace reload overlay ──────────────────────────────────────
                           A non-blocking spinner banner shown while ReloadWorkspaceAsync runs
                           (enterprise/year change, manual refresh).  The existing content stays
                           rendered beneath it so the user sees familiar context while the API
                           round-trip completes.
                           ──────────────────────────────────────────────────────────────────── *@
                        else if (IsLoadingWorkspace)
                        {
                            <div id="workspace-reload-skeleton" aria-busy="true" aria-label="Workspace reloading" class="space-y-4">
                                <div class="flex items-center gap-4 rounded-2xl border border-sky-200 bg-sky-50 px-6 py-4">
                                    <div class="wiley-panel-spinner-host" style="min-height:3rem; width:3rem;">
                                        <SfSpinner Visible="true" Size="28" Type="SpinnerType.Material" />
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-sky-900">Loading workspace…</p>
                                        <p class="mt-0.5 text-xs text-sky-700">@WorkspaceLoadStatus</p>
                                    </div>
                                </div>
                                @* Skeleton rows matching the active mode *@
                                @if (IsOverviewMode)
                                {
                                    <div class="wiley-overview-skeleton-grid">
                                        @for (int i = 0; i < 6; i++)
                                        {
                                            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm space-y-3">
                                                <div class="wiley-skeleton h-3 w-1/3 rounded"></div>
                                                <div class="wiley-skeleton h-5 w-2/3 rounded"></div>
                                                <div class="wiley-skeleton h-3 w-full rounded"></div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="space-y-3 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                                        <div class="wiley-skeleton h-6 w-1/2 rounded"></div>
                                        <div class="wiley-skeleton h-4 w-3/4 rounded"></div>
                                        <div class="wiley-skeleton h-4 w-2/3 rounded"></div>
                                        <div class="mt-4 wiley-skeleton h-48 w-full rounded-xl"></div>
                                    </div>
                                }
                            </div>
                        }
                        else if (IsOverviewMode)
                        {
                            <section id="workspace-overview-dashboard" class="workspace-overview-grid flex-1" aria-label="Workspace overview panels">
                                <article id="overview-break-even" class="workspace-overview-card workspace-overview-card-featured">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Break-Even</p>
                                        <h3>Core rate position</h3>
                                        <p>Current @CurrentRateDisplay, recommended @BreakEvenRateDisplay, and delta @RateDeltaDisplay with direct baseline controls.</p>
                                        <div class="workspace-overview-card-metrics">
                                            <span>Total costs @TotalCostsDisplay</span>
                                            <span>Projected volume @ProjectedVolumeDisplay</span>
                                        </div>
                                    </div>
                                    <button type='button' class='workspace-card-link workspace-card-link-primary' @onclick='() => OpenPanel("break-even")'>Open Break-Even</button>
                                </article>

                                <article id="overview-apartment-config" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Apartment Config</p>
                                        <h3>Apartment unit mix</h3>
                                        <p>Edit unit counts, rent assumptions, and bedroom weighting for the Apartments enterprise without leaving the workspace shell.</p>
                                        <div class="workspace-overview-card-metrics">
                                            <span>Units @ApartmentUnitTypes.Sum(unitType => unitType.UnitCount).ToString("N0")</span>
                                            <span>Revenue @ApartmentUnitTypes.Sum(unitType => unitType.UnitCount * unitType.MonthlyRent).ToString("C0")</span>
                                        </div>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("apartment-config")'>Open Apartment Config</button>
                                </article>

                                <article id="overview-rates" class="workspace-overview-card workspace-overview-card-featured">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Rates</p>
                                        <h3>Editable rate controls</h3>
                                        <p>Adjust the current rate, compare it against the recommendation, and save a point-in-time snapshot.</p>
                                        <div class="workspace-overview-card-metrics">
                                            <span>Current @CurrentRateDisplay</span>
                                            <span>Target @BreakEvenRateDisplay</span>
                                        </div>
                                    </div>
                                    <button type='button' class='workspace-card-link workspace-card-link-primary' @onclick='() => OpenPanel("rates")'>Open Rates</button>
                                </article>

                                <article id="overview-import" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">QuickBooks Import</p>
                                        <h3>Ingest and validate source records</h3>
                                        <p>Upload QuickBooks exports, inspect validation feedback, and stage records before commit.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("quickbooks-import")'>Open Import</button>
                                </article>

                                <article id="overview-scenario" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Scenario Planner</p>
                                        <h3>Model what-if changes</h3>
                                        <p>Stress cost assumptions, compare adjusted break-even outcomes, and persist named scenarios.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("scenario")'>Open Scenario Planner</button>
                                </article>

                                <article id="overview-customers" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Customer Viewer</p>
                                        <h3>Review affected accounts</h3>
                                        <p>@FilteredCustomerCountDisplay customers currently match the active filters for export and operational review.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("customers")'>Open Customer Viewer</button>
                                </article>

                                <article id="overview-affordability" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Affordability</p>
                                        <h3>Bill burden versus MHI</h3>
                                        <p>See how modeled monthly bills compare to median household income across customer classes and rate scenarios.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("affordability")'>Open Affordability</button>
                                </article>

                                <article id="overview-debt-coverage" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Debt Coverage</p>
                                        <h3>DSCR and covenant headroom</h3>
                                        <p>Check annual revenue against debt service, compare the ratio to a covenant floor, and inspect residual headroom.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("debt-coverage")'>Open Debt Coverage</button>
                                </article>

                                <article id="overview-capital-gap" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Capital Gap</p>
                                        <h3>Capital needs versus rate revenue</h3>
                                        <p>Track capital-tagged budget items against rate revenue and watch the cumulative headroom line move as items accumulate.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("capital-gap")'>Open Capital Gap</button>
                                </article>

                                <article id="overview-reserve-trajectory" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Reserve Trajectory</p>
                                        <h3>Forecast reserve runway</h3>
                                        <p>Review current reserves, the recommended reserve floor, and the forecast outlook before opening the trajectory panel.</p>
                                        <div class="workspace-overview-card-metrics">
                                            <span>Current @(ReserveTrajectory is null ? "Unavailable" : ReserveTrajectory.CurrentReserves.ToString("C0"))</span>
                                            <span>Policy minimum @(ReserveTrajectory is null ? "Unavailable" : ReserveTrajectory.RecommendedReserveLevel.ToString("C0"))</span>
                                        </div>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("reserve-trajectory")'>Open Reserve Trajectory</button>
                                </article>

                                <article id="overview-trends" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Trends</p>
                                        <h3>Projected rate movement</h3>
                                        <p>Inspect the year-by-year rate line and understand how the active assumptions move over time.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("trends")'>Open Trends</button>
                                </article>

                                <article id="overview-ai" class="workspace-overview-card">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Decision Support</p>
                                        <h3>Jarvis guidance</h3>
                                        <p>Pull context-aware recommendations tied to the current enterprise, year, and scenario state.</p>
                                    </div>
                                    <button type='button' class='workspace-card-link' @onclick='() => OpenPanel("decision-support")'>Open Decision Support</button>
                                </article>

                                <article id="overview-data-dashboard" class="workspace-overview-card workspace-overview-card-wide">
                                    <div class="workspace-overview-card-copy">
                                        <p class="workspace-overview-card-kicker">Data Dashboard</p>
                                        <h3>Executive visual summary</h3>
                                        <p>KPI gauges, scenario pressure, customer mix, and trend visuals in one consolidated dashboard.</p>
                                        <div class="workspace-overview-card-metrics">
                                            <span>Enterprise @SelectedEnterprise</span>
                                            <span>Fiscal year @SelectedFiscalYear</span>
                                            <span>Scenario pressure @ScenarioCostTotalDisplay</span>
                                        </div>
                                    </div>
                                    <button type='button' class='workspace-card-link workspace-card-link-primary' @onclick='() => OpenPanel("data-dashboard")'>Open Data Dashboard</button>
                                </article>
                            </section>
                        }
                        else
                        {
                            <div class="flex-1 overflow-auto pr-1">
                                @switch (ActivePanelKey)
                                {
                                    case "break-even":
                                        <BreakEvenPanel @key="ActivePanelKey"
                                                        TotalCosts="@TotalCosts"
                                                        ProjectedVolume="@ProjectedVolume"
                                                        TotalCostsDisplay="@TotalCostsDisplay"
                                                        ProjectedVolumeDisplay="@ProjectedVolumeDisplay"
                                                        RateDeltaDisplay="@RateDeltaDisplay"
                                                        BreakEvenRateDisplay="@BreakEvenRateDisplay"
                                                        IsSavingBaseline="@IsSavingBaseline"
                                                        BaselineSaveStatus="@BaselineSaveStatus"
                                                        Quadrants="@BreakEvenQuadrants"
                                                        ApartmentUnitTypes="@ApartmentUnitTypes"
                                                        OnTotalCostsChanged="HandleTotalCostsChanged"
                                                        OnProjectedVolumeChanged="HandleProjectedVolumeChanged"
                                                        OnSaveWorkspaceBaseline="SaveWorkspaceBaselineAsync"
                                                        OnApartmentUnitTypesChanged="HandleApartmentUnitTypesChanged" />
                                        break;
                                    case "apartment-config":
                                        <ApartmentConfigPanel @key="ActivePanelKey"
                                                              UnitTypes="@ApartmentUnitTypes"
                                                              OnUnitTypesChanged="HandleApartmentUnitTypesChanged" />
                                        break;
                                    case "rates":
                                        <RatesPanel @key="ActivePanelKey"
                                                    CurrentRate="@CurrentRate"
                                                    CurrentRateDisplay="@CurrentRateDisplay"
                                                    BreakEvenRateDisplay="@BreakEvenRateDisplay"
                                                    IsSavingSnapshot="@IsSavingSnapshot"
                                                    SnapshotSaveStatus="@SnapshotSaveStatus"
                                                    RateComparison="@RateComparison"
                                                    OnCurrentRateChanged="HandleCurrentRateChanged"
                                                    OnSaveRateSnapshot="SaveRateSnapshotAsync" />
                                        break;
                                    case "quickbooks-import":
                                        <QuickBooksImportPanelWrapper @key="ActivePanelKey" WorkspaceState="@WorkspaceState" />
                                        break;
                                    case "scenario":
                                        <ScenarioPlannerPanel @key="ActivePanelKey"
                                                              ScenarioAdjustedRate="@ScenarioAdjustedRate"
                                                              ScenarioCostTotal="@ScenarioCostTotal"
                                                              ScenarioAdjustedDelta="@ScenarioAdjustedDelta"
                                                              CurrentRate="@CurrentRate"
                                                              BreakEvenRateDisplay="@BreakEvenRateDisplay"
                                                              ScenarioAdjustedRateDisplay="@ScenarioAdjustedRateDisplay"
                                                              ScenarioCostTotalDisplay="@ScenarioCostTotalDisplay"
                                                              ScenarioAdjustedDeltaDisplay="@ScenarioAdjustedDeltaDisplay"
                                                              ScenarioItems="@ScenarioItems"
                                                              ScenarioToolbarItems="@ScenarioToolbarItems"
                                                              OnScenarioGridActionComplete="HandleScenarioGridActionComplete" />
                                        break;
                                    case "customers":
                                        <CustomerViewerPanel @key="ActivePanelKey" />
                                        break;
                                    case "affordability":
                                        <AffordabilityDashboardPanel @key="ActivePanelKey"
                                                                     Customers="@Customers"
                                                                     SelectedEnterprise="@SelectedEnterprise"
                                                                     SelectedFiscalYear="@SelectedFiscalYear" />
                                        break;
                                    case "trends":
                                        <TrendsPanel @key="ActivePanelKey" ProjectionSeries="@ProjectionSeries" />
                                        break;
                                    case "reserve-trajectory":
                                        <ReserveTrajectoryPanel @key="ActivePanelKey"
                                                               Trajectory="@ReserveTrajectory"
                                                               OnExportPdf="ExportReserveTrajectoryPdfAsync"
                                                               OnExportExcel="ExportReserveTrajectoryWorkbookAsync" />
                                        break;
                                    case "debt-coverage":
                                        <DebtCoveragePanel @key="ActivePanelKey"
                                                           SelectedEnterprise="@SelectedEnterprise"
                                                           SelectedFiscalYear="@SelectedFiscalYear" />
                                        break;
                                    case "capital-gap":
                                        <CapitalGapPanel @key="ActivePanelKey"
                                                         SelectedEnterprise="@SelectedEnterprise"
                                                         SelectedFiscalYear="@SelectedFiscalYear" />
                                        break;
                                    case "decision-support":
                                        <DecisionSupportPanel @key="ActivePanelKey" />
                                        break;
                                    case "data-dashboard":
                                        <DataDashboardPanel @key="ActivePanelKey"
                                                            CurrentRate="@CurrentRate"
                                                            TotalCosts="@TotalCosts"
                                                            ProjectedVolume="@ProjectedVolume"
                                                            RecommendedRate="@RecommendedRate"
                                                            AdjustedRecommendedRate="@ScenarioAdjustedRate"
                                                            ScenarioCostTotal="@ScenarioCostTotal"
                                                            ScenarioItems="@ScenarioItems"
                                                            ProjectionSeries="@ProjectionSeries"
                                                            Customers="@Customers"
                                                            RateComparison="@RateComparison"
                                                            SelectedEnterprise="@SelectedEnterprise"
                                                            SelectedFiscalYear="@SelectedFiscalYear" />
                                        break;
                                    default:
                                        NavigationManager.NavigateTo("/wiley-workspace", replace: true);
                                        break;
                                }
                            </div>
                        }
                    </div>
                        </div>
                        </div>
                    </ContentTemplate>
                </SplitterPane>

                @* Jarvis Rail – pane 2: AI chat, starts collapsed *@
                <SplitterPane Size="340px" Min="48px" Max="520px" Resizable="true" Collapsible="true" Collapsed="true">
                    <ContentTemplate>
                        <div id="workspace-jarvis-rail" class="workspace-pane-jarvis flex flex-col h-full">
                            <div class="workspace-jarvis-rail-header flex items-center gap-3 border-b border-slate-200 px-4 py-3 flex-shrink-0">
                                <span class="e-icons e-ai-chat text-sky-600 text-base flex-shrink-0" aria-hidden="true"></span>
                                <div class="min-w-0">
                                    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Jarvis</p>
                                    <p class="mt-0.5 text-[0.7rem] text-slate-400 leading-tight">AI workspace guidance</p>
                                </div>
                            </div>
                            <div class="min-h-0 flex-1 overflow-auto p-3">
                                <JarvisChatPanel />
                            </div>
