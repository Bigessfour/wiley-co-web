@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Notifications
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.ProgressBar
@using WileyCoWeb.Contracts
@using WileyCoWeb.Services
@using WileyCoWeb.State
@using WileyWidget.Models

@inject QuickBooksImportApiService ImportApi

<SfCard CssClass="h-full">
    <CardHeader Title="QuickBooks Import" SubTitle="Clerk-facing CSV/XLSX intake with preview, duplicate checks, and commit confirmation." />
    <CardContent>
        <div id="quickbooks-import-drop-area" aria-busy="@IsBusy" class="space-y-4">
            <SfProgressBar Type="ProgressType.Linear"
                           Value="@ImportProgress"
                           Maximum="100"
                           ShowProgressValue="false"
                           IsIndeterminate="@IsBusy"
                           Height="8px" />

            <div class="grid gap-3 md:grid-cols-2">
                <SfDropDownList TValue="string" TItem="string" DataSource="@WorkspaceState.EnterpriseOptions" @bind-Value="WorkspaceState.SelectedEnterprise" Placeholder="Enterprise" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" ShowClearButton="true" PopupHeight="240px" Width="100%" />
                <SfDropDownList TValue="int" TItem="int" DataSource="@WorkspaceState.FiscalYearOptions" @bind-Value="WorkspaceState.SelectedFiscalYear" Placeholder="Fiscal Year" FloatLabelType="FloatLabelType.Auto" ShowClearButton="false" PopupHeight="240px" Width="100%" />
            </div>

            <SfStepper ActiveStep="@ActiveStep" Linear="true" Orientation="StepperOrientation.Horizontal" StepType="StepperType.Indicator" LabelPosition="StepperLabelPosition.Bottom" ShowTooltip="true">
                <StepperSteps>
                    <StepperStep Label="Context" Text="Select the enterprise and fiscal year"></StepperStep>
                    <StepperStep Label="Upload" Text="Choose a QuickBooks export"></StepperStep>
                    <StepperStep Label="Preview" Text="Review parsed rows and assistant guidance"></StepperStep>
                    <StepperStep Label="Commit" Text="Persist the import when duplicate checks pass"></StepperStep>
                </StepperSteps>
            </SfStepper>

            <div class="grid gap-2 text-xs text-slate-500 sm:grid-cols-4">
                <div>1. Select the enterprise and fiscal year.</div>
                <div>2. Upload a QuickBooks Desktop export.</div>
                <div>3. Review the preview and assistant guidance.</div>
                <div>4. Commit only if the file is not a duplicate.</div>
            </div>

            <div class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <label for="quickbooks-import-uploader" class="e-btn e-control e-lib cursor-pointer">Choose QuickBooks file</label>
                        <InputFile @key="FileInputRenderKey"
                                   id="quickbooks-import-uploader"
                                   class="hidden"
                                   OnChange="HandleFileSelectedAsync"
                                   accept=".csv,.xlsx,.xls" />
                        <span class="text-xs text-slate-500">CSV or Excel, up to 50 MB.</span>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-2">
                        <SfCard>
                            <CardHeader Title="Selected File" SubTitle="@SelectedFileLabel" />
                            <CardContent Content="Upload a QuickBooks export to preview the parsed ledger rows." />
                        </SfCard>
                        <SfCard>
                            <CardHeader Title="Import Status" SubTitle="@StatusHeadline" />
                            <CardContent Content="@StatusMessage" />
                        </SfCard>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700" role="status" aria-live="polite">
                        <div id="quickbooks-import-status-headline" class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">@StatusHeadline</div>
                        <div id="quickbooks-import-status-message" class="mt-1 whitespace-pre-line">@StatusMessage</div>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3" aria-busy="@IsBusy">
                        <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@(!CanAnalyze)" OnClick="LoadPreviewAsync">Analyze file</SfButton>
                        <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@(!CanCommit || IsBusy)" OnClick="OpenCommitDialogAsync">Commit import</SfButton>
                        <SfButton Disabled="@IsBusy" OnClick="ClearSelectionAsync">Reset panel</SfButton>
                    </div>

                    <SfCard>
                        <CardHeader Title="Import assistant" SubTitle="Ask semantic questions about this QuickBooks file, preview, or troubleshooting steps." />
                        <CardContent>
                            <div class="space-y-3">
                                <SfTextBox Placeholder="Ask about duplicate detection, column mapping, dates, or commit errors"
                                           ID="quickbooks-assistant-question"
                                           FloatLabelType="FloatLabelType.Auto"
                                           Multiline="true"
                                           Rows="4"
                                           @bind-Value="AssistantQuestion" />
                                <div class="flex flex-wrap gap-3">
                                    <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@(!CanAskAssistant)" OnClick="AskAssistantAsync">Ask assistant</SfButton>
                                    <SfButton Disabled="@IsAskingAssistant" OnClick="ClearAssistantAsync">Clear answer</SfButton>
                                </div>
                                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700" role="status" aria-live="polite" aria-busy="@IsAskingAssistant">
                                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Context</p>
                                    <p id="quickbooks-assistant-context-summary" class="mt-1 text-slate-900">@AssistantContextSummary</p>
                                    <p id="quickbooks-assistant-answer" class="mt-3 whitespace-pre-line">@AssistantAnswer</p>
                                </div>
                            </div>
                        </CardContent>
                    </SfCard>
                </div>

                <div class="space-y-4">
                    <div class="grid gap-3 sm:grid-cols-3">
                        <SfCard>
                            <CardHeader Title="Rows" SubTitle="@RowCountDisplay" />
                            <CardContent Content="Rows parsed from the selected export." />
                        </SfCard>
                        <SfCard>
                            <CardHeader Title="Duplicates" SubTitle="@DuplicateCountDisplay" />
                            <CardContent Content="Rows or file-level duplicates detected from the file hash." />
                        </SfCard>
                        <SfCard>
                            <CardHeader Title="Enterprise" SubTitle="@WorkspaceState.SelectedEnterprise" />
                            <CardContent Content="The active enterprise and fiscal year drive import context." />
                        </SfCard>
                    </div>

                    @if (PreviewRows.Count > 0)
                    {
                        <SfGrid TValue="QuickBooksImportPreviewRow" DataSource="@PreviewRows" AllowPaging="true" AllowSorting="true" AllowFiltering="true" AllowTextWrap="true" AllowResizing="true" EnableHover="true" EnableStickyHeader="true" ClipMode="ClipMode.EllipsisWithTooltip" GridLines="GridLine.Horizontal" Height="320">
                            <GridPageSettings PageSize="5" PageCount="3" />
                            <GridColumns>
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.RowNumber)" HeaderText="Row" Width="70" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.EntryDate)" HeaderText="Date" Width="110" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.EntryType)" HeaderText="Type" Width="110" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.Name)" HeaderText="Name" Width="140" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.AccountName)" HeaderText="Account" Width="160" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.RoutedEnterprise)" HeaderText="Routed Enterprise" Width="160" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.RoutingRuleName)" HeaderText="Rule" Width="150" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.AllocationSummary)" HeaderText="Allocation" Width="190" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.SourceAmount)" HeaderText="Source Amount" Format="C2" Width="120" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.Amount)" HeaderText="Amount" Format="C2" Width="110" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" />
                                <GridColumn Field="@nameof(QuickBooksImportPreviewRow.IsDuplicate)" HeaderText="Duplicate" Width="100" Type="Syncfusion.Blazor.Grids.ColumnType.Boolean" />
                            </GridColumns>
                        </SfGrid>
                    }
                    else
                    {
                        <SfCard>
                            <CardHeader Title="Preview" SubTitle="Nothing loaded yet" />
                            <CardContent Content="Choose a QuickBooks CSV or Excel export, then analyze it to load the preview grid." />
                        </SfCard>
                    }
                </div>
            </div>

            <SfTab OverflowMode="OverflowMode.Scrollable">
                <TabItems>
                    <TabItem>
                        <ChildContent>
                            <TabHeader Text="Routing Rules" />
                        </ChildContent>
                        <ContentTemplate>
                            <div class="space-y-4 pt-4">
                                <div class="flex flex-wrap items-center gap-3">
                                    <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsRoutingBusy" OnClick="LoadRoutingWorkspaceAsync">Refresh routing</SfButton>
                                    <SfButton Disabled="@IsRoutingBusy" OnClick="AddRoutingRule">Add rule</SfButton>
                                    <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsRoutingBusy" OnClick="SaveRoutingConfigurationAsync">Save routing</SfButton>
                                </div>

                                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700" role="status" aria-live="polite" aria-busy="@IsRoutingBusy">
                                    <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Routing status</div>
                                    <div class="mt-1 whitespace-pre-line">@RoutingStatusMessage</div>
                                </div>

                                @if (RoutingRules.Count == 0)
                                {
                                    <SfCard>
                                        <CardHeader Title="No routing rules" SubTitle="Add a rule to override file-level enterprise routing." />
                                        <CardContent Content="Rules can match file names, account names, memo text, names, or split accounts. Leave fields blank to keep a rule broad." />
                                    </SfCard>
                                }
                                else
                                {
                                    @foreach (var rule in RoutingRules.OrderBy(item => item.Priority).ThenBy(item => item.Name, StringComparer.OrdinalIgnoreCase))
                                    {
                                        var currentRule = rule;
                                        <SfCard>
                                            <CardHeader Title="@GetRuleTitle(currentRule)" SubTitle="@GetRuleSubtitle(currentRule)" />
                                            <CardContent>
                                                <div class="space-y-3">
                                                    <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
                                                        <SfTextBox Placeholder="Rule name" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.Name" />
                                                        <SfNumericTextBox TValue="int" Placeholder="Priority" FloatLabelType="FloatLabelType.Auto" Min="0" Step="10" Format="n0" @bind-Value="currentRule.Priority" />
                                                        <SfDropDownList TValue="string" TItem="string" DataSource="@RoutingEnterpriseOptions" @bind-Value="currentRule.TargetEnterprise" Placeholder="Target enterprise" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" Width="100%" />
                                                        <SfDropDownList TValue="long?" TItem="QuickBooksAllocationProfileOption" DataSource="@GetAllocationProfileOptions()" @bind-Value="currentRule.AllocationProfileId" Placeholder="Allocation profile" FloatLabelType="FloatLabelType.Auto" Width="100%">
                                                            <DropDownListFieldSettings Text="Name" Value="Id" />
                                                        </SfDropDownList>
                                                    </div>

                                                    <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
                                                        <SfTextBox Placeholder="Source file pattern" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.SourceFilePattern" />
                                                        <SfTextBox Placeholder="Default enterprise pattern" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.DefaultEnterprisePattern" />
                                                        <SfTextBox Placeholder="Account pattern" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.AccountPattern" />
                                                        <SfTextBox Placeholder="Memo pattern" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.MemoPattern" />
                                                        <SfTextBox Placeholder="Name pattern" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.NamePattern" />
                                                        <SfTextBox Placeholder="Split account pattern" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentRule.SplitAccountPattern" />
                                                    </div>

                                                    <SfTextBox Placeholder="Description" FloatLabelType="FloatLabelType.Auto" Multiline="true" Rows="2" @bind-Value="currentRule.Description" />

                                                    <div class="flex flex-wrap items-center gap-3">
                                                        <SfCheckBox TChecked="bool" Label="Rule active" @bind-Checked="currentRule.IsActive" />
                                                        <SfButton Disabled="@IsRoutingBusy" OnClick="@(() => RemoveRoutingRule(currentRule))">Remove rule</SfButton>
                                                    </div>
                                                </div>
                                            </CardContent>
                                        </SfCard>
                                    }
                                }
                            </div>
                        </ContentTemplate>
                    </TabItem>
                    <TabItem>
                        <ChildContent>
                            <TabHeader Text="Allocation Profiles" />
                        </ChildContent>
                        <ContentTemplate>
                            <div class="space-y-4 pt-4">
                                <div class="flex flex-wrap items-center gap-3">
                                    <SfButton Disabled="@IsRoutingBusy" OnClick="AddAllocationProfile">Add profile</SfButton>
                                    <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsRoutingBusy" OnClick="SaveRoutingConfigurationAsync">Save routing</SfButton>
                                </div>

                                @if (AllocationProfiles.Count == 0)
                                {
                                    <SfCard>
                                        <CardHeader Title="No allocation profiles" SubTitle="Create reusable shared-cost splits here." />
                                        <CardContent Content="Allocation profiles let a single QuickBooks row distribute its amount across multiple enterprises and keep historical reroutes reproducible." />
                                    </SfCard>
                                }
                                else
                                {
                                    @foreach (var profile in AllocationProfiles.OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase))
                                    {
                                        var currentProfile = profile;
                                        <SfCard>
                                            <CardHeader Title="@GetProfileTitle(currentProfile)" SubTitle="@GetProfileSubtitle(currentProfile)" />
                                            <CardContent>
                                                <div class="space-y-3">
                                                    <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
                                                        <SfTextBox Placeholder="Profile name" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentProfile.Name" />
                                                        <SfTextBox Placeholder="Description" FloatLabelType="FloatLabelType.Auto" @bind-Value="currentProfile.Description" />
                                                        <div class="flex items-center pt-4">
                                                            <SfCheckBox TChecked="bool" Label="Profile active" @bind-Checked="currentProfile.IsActive" />
                                                        </div>
                                                        <div class="flex items-center pt-2">
                                                            <SfButton Disabled="@IsRoutingBusy" OnClick="@(() => RemoveAllocationProfile(currentProfile))">Remove profile</SfButton>
                                                        </div>
                                                    </div>

                                                    @if (currentProfile.Targets.Count == 0)
                                                    {
                                                        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-3 text-sm text-slate-600">
                                                            Add one or more enterprise targets. If the total is under 100%, the remainder stays with the rule target enterprise.
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var target in currentProfile.Targets.OrderBy(item => item.EnterpriseName, StringComparer.OrdinalIgnoreCase))
                                                        {
                                                            var currentTarget = target;
                                                            <div class="grid gap-3 rounded-2xl border border-slate-200 p-3 md:grid-cols-[1fr_180px_auto]">
                                                                <SfDropDownList TValue="string" TItem="string" DataSource="@RoutingEnterpriseOptions" @bind-Value="currentTarget.EnterpriseName" Placeholder="Enterprise" FloatLabelType="FloatLabelType.Auto" AllowFiltering="true" FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" IgnoreCase="true" Width="100%" />
                                                                <SfNumericTextBox TValue="decimal" Placeholder="Percent" FloatLabelType="FloatLabelType.Auto" Min="0" Max="100" Step="5" Decimals="2" Format="n2" @bind-Value="currentTarget.AllocationPercent" />
                                                                <div class="flex items-center pt-2">
                                                                    <SfButton Disabled="@IsRoutingBusy" OnClick="@(() => RemoveAllocationTarget(currentProfile, currentTarget))">Remove target</SfButton>
                                                                </div>
                                                            </div>
                                                        }
                                                    }

                                                    <div class="flex flex-wrap items-center gap-3">
                                                        <SfButton Disabled="@IsRoutingBusy" OnClick="@(() => AddAllocationTarget(currentProfile))">Add target</SfButton>
                                                        <span class="text-sm text-slate-500">Current total: @GetAllocationPercentDisplay(currentProfile)</span>
                                                    </div>
                                                </div>
                                            </CardContent>
                                        </SfCard>
                                    }
                                }
                            </div>
                        </ContentTemplate>
                    </TabItem>
                    <TabItem>
                        <ChildContent>
                            <TabHeader Text="Import History" />
                        </ChildContent>
                        <ContentTemplate>
                            <div class="space-y-4 pt-4">
                                <div class="flex flex-wrap items-center gap-3">
                                    <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@IsRoutingBusy" OnClick="LoadImportHistoryAsync">Refresh history</SfButton>
                                </div>

                                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700" role="status" aria-live="polite">
                                    <div class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">History status</div>
                                    <div class="mt-1 whitespace-pre-line">@ImportHistoryStatusMessage</div>
                                </div>

                                @if (ImportHistoryItems.Count == 0)
                                {
                                    <SfCard>
                                        <CardHeader Title="No import history" SubTitle="Committed QuickBooks source files will appear here." />
                                        <CardContent Content="Historical reroute lets you apply the latest routing rules to an already-imported source file so downstream calculations update consistently." />
                                    </SfCard>
                                }
                                else
                                {
                                    @foreach (var item in ImportHistoryItems)
                                    {
                                        var currentItem = item;
                                        <SfCard>
                                            <CardHeader Title="@currentItem.FileName" SubTitle="@GetHistorySubtitle(currentItem)" />
                                            <CardContent>
                                                <div class="flex flex-wrap items-center gap-3">
                                                    <span class="text-sm text-slate-600">Source file ID: @currentItem.SourceFileId</span>
                                                    <span class="text-sm text-slate-600">Batch ID: @currentItem.BatchId</span>
                                                    <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@(IsRoutingBusy || ReroutingSourceFileId == currentItem.SourceFileId)" OnClick="@(() => ReapplyRoutingAsync(currentItem))">
                                                        @(ReroutingSourceFileId == currentItem.SourceFileId ? "Reapplying..." : "Reapply routing")
                                                    </SfButton>
                                                </div>
                                            </CardContent>
                                        </SfCard>
                                    }
                                }
                            </div>
                        </ContentTemplate>
                    </TabItem>
                </TabItems>
            </SfTab>
        </div>
    </CardContent>
</SfCard>

<SfDialog @bind-Visible="ShowCommitDialog"
          Header="Confirm QuickBooks import"
          Width="540px"
          IsModal="true"
          CloseOnEscape="true"
          ShowCloseIcon="true">
    <DialogTemplates>
        <Content>
            <div class="space-y-3">
                <p>This will commit @RowCountDisplay rows for @WorkspaceState.SelectedEnterprise FY @WorkspaceState.SelectedFiscalYear.</p>
                <p class="text-sm text-slate-600">QuickBooks actuals remain canonical. The import is blocked only if the same file has already been imported.</p>
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Cancel" OnClick="CloseCommitDialogAsync" />
        <DialogButton Content="Commit now" CssClass="e-primary" IsPrimary="true" OnClick="CommitImportAsync" />
    </DialogButtons>
</SfDialog>

<SfToast @ref="ToastRef" Title="QuickBooks import" Timeout="4000" ShowCloseButton="true" ShowProgressBar="true" NewestOnTop="true" Width="360px" ProgressDirection="ProgressDirection.LTR">
    <ToastPosition X="Right" Y="Top" />
</SfToast>

@code {
    private static readonly HashSet<string> SupportedFileExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".csv",
        ".xlsx",
        ".xls"
    };

    private const long MaxImportFileSize = 52_428_800;

    [Parameter]
    public WorkspaceState WorkspaceState { get; set; } = default!;

    private readonly JsonSerializerOptions jsonOptions = new(JsonSerializerDefaults.Web);
    private readonly List<QuickBooksImportPreviewRow> PreviewRows = [];
    private SfToast? ToastRef;
    private byte[]? SelectedFileBytes;
    private string SelectedFileName = string.Empty;
    private string FileInputRenderKey = Guid.NewGuid().ToString("N");
    private QuickBooksImportPreviewResponse? PreviewResponse;
    private string AssistantQuestion = string.Empty;
    private string AssistantAnswer = "Load a QuickBooks preview, then ask a question about the rows or troubleshooting steps.";
    private string AssistantContextSummary = "No QuickBooks preview has been loaded yet.";
    private bool ShowCommitDialog;
    private bool IsBusy;
    private bool IsAskingAssistant;
    private bool IsRoutingBusy;
    private int ActiveStep;
    private int ImportProgress;
    private string StatusHeadline = "Ready";
    private string StatusMessage = "Choose a QuickBooks export to begin.";
    private string RoutingStatusMessage = "Routing rules and allocation profiles can be managed from this panel.";
    private string ImportHistoryStatusMessage = "Load routing history to manage previously imported QuickBooks files.";
    private long? ReroutingSourceFileId;
    private List<QuickBooksRoutingRuleDefinition> RoutingRules { get; } = [];
    private List<QuickBooksAllocationProfileDefinition> AllocationProfiles { get; } = [];
    private List<QuickBooksImportHistoryItem> ImportHistoryItems { get; } = [];

    private string SelectedFileLabel => string.IsNullOrWhiteSpace(SelectedFileName) ? "No file selected" : SelectedFileName;

    private string RowCountDisplay => PreviewResponse?.TotalRows.ToString(CultureInfo.InvariantCulture) ?? "0";

    private string DuplicateCountDisplay => PreviewResponse?.DuplicateRows.ToString(CultureInfo.InvariantCulture) ?? "0";

    private bool CanAnalyze => SelectedFileBytes is { Length: > 0 } && !IsBusy;

    private bool CanCommit => SelectedFileBytes is { Length: > 0 } && PreviewResponse is not null && !PreviewResponse.IsDuplicate;

    private bool CanAskAssistant => PreviewResponse is not null && !string.IsNullOrWhiteSpace(AssistantQuestion) && !IsBusy && !IsAskingAssistant;

    private IReadOnlyList<string> RoutingEnterpriseOptions => WorkspaceState.EnterpriseOptions
        .Where(option => !string.IsNullOrWhiteSpace(option) && !string.Equals(option, "general_ledger", StringComparison.OrdinalIgnoreCase) && !string.Equals(option, "transaction_list", StringComparison.OrdinalIgnoreCase))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(option => option, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadRoutingWorkspaceAsync().ConfigureAwait(false);
    }

    protected override void OnParametersSet()
    {
        if (WorkspaceState is null)
        {
            throw new InvalidOperationException("WorkspaceState is required.");
        }
    }

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs args)
    {
        var browserFile = args.FileCount > 0 ? args.File : null;

        if (browserFile is null)
        {
            await ClearSelectionAsync().ConfigureAwait(false);
            return;
        }

        try
        {
            await using var fileStream = browserFile.OpenReadStream(MaxImportFileSize);
            await using var memoryStream = new MemoryStream();
            await fileStream.CopyToAsync(memoryStream).ConfigureAwait(false);

            SelectedFileBytes = memoryStream.ToArray();
            SelectedFileName = browserFile.Name;
        }
        catch (Exception ex)
        {
            SelectedFileBytes = null;
            SelectedFileName = string.Empty;
            StatusHeadline = "File selection failed";
            StatusMessage = ex.Message;
            ShowCommitDialog = false;
            await ShowToastAsync("QuickBooks import", StatusMessage).ConfigureAwait(false);
            await InvokeAsync(StateHasChanged);
            return;
        }

        PreviewResponse = null;
        PreviewRows.Clear();
        AssistantQuestion = string.Empty;
        AssistantAnswer = "Load a QuickBooks preview, then ask a question about the rows or troubleshooting steps.";
        AssistantContextSummary = "No QuickBooks preview has been loaded yet.";
        StatusHeadline = "File selected";
        StatusMessage = string.IsNullOrWhiteSpace(SelectedFileName)
            ? "Select a QuickBooks export to continue."
            : $"{SelectedFileName} is ready for preview.";
        ActiveStep = 0;
        ImportProgress = 20;
        ShowCommitDialog = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenCommitDialogAsync()
    {
        if (!CanCommit)
        {
            StatusHeadline = "Nothing to commit";
            StatusMessage = "Analyze a valid, non-duplicate QuickBooks export before committing it.";
            await ShowToastAsync("QuickBooks import", StatusMessage).ConfigureAwait(false);
            return;
        }

        ShowCommitDialog = true;
        await InvokeAsync(StateHasChanged);
    }

    private Task CloseCommitDialogAsync()
    {
        ShowCommitDialog = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task CommitImportAsync()
    {
        if (!await EnsureSelectedFileIsValidAsync("commit").ConfigureAwait(false))
        {
            return;
        }

        var selectedFileBytes = SelectedFileBytes;

        try
        {
            IsBusy = true;
            ImportProgress = 90;
            await InvokeAsync(StateHasChanged);

            var result = await ImportApi.CommitAsync(selectedFileBytes!, SelectedFileName, WorkspaceState.SelectedEnterprise, WorkspaceState.SelectedFiscalYear).ConfigureAwait(false);

            var previewRowsSnapshot = PreviewRows.ToList();

            PreviewResponse = new QuickBooksImportPreviewResponse(
                result.FileName,
                result.FileHash,
                result.SelectedEnterprise,
                result.SelectedFiscalYear,
                result.ImportedRows,
                0,
                result.IsDuplicate,
                result.StatusMessage,
                previewRowsSnapshot);

            SelectedFileBytes = null;
            FileInputRenderKey = Guid.NewGuid().ToString("N");
            AssistantContextSummary = BuildAssistantContextSummary(PreviewResponse);
            StatusHeadline = result.IsDuplicate ? "Duplicate blocked" : "Import complete";
            StatusMessage = result.StatusMessage;
            ActiveStep = 3;
            ImportProgress = 100;
            ShowCommitDialog = false;
            await ShowToastAsync(StatusHeadline, StatusMessage).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            StatusHeadline = "Commit failed";
            StatusMessage = ex.Message;
            await ShowToastAsync(StatusHeadline, StatusMessage).ConfigureAwait(false);
        }
        finally
        {
            IsBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPreviewAsync()
    {
        if (!await EnsureSelectedFileIsValidAsync("preview").ConfigureAwait(false))
        {
            return;
        }

        var selectedFileBytes = SelectedFileBytes;

        try
        {
            IsBusy = true;
            ImportProgress = 60;
            await InvokeAsync(StateHasChanged);

            var preview = await ImportApi.PreviewAsync(selectedFileBytes!, SelectedFileName, WorkspaceState.SelectedEnterprise, WorkspaceState.SelectedFiscalYear).ConfigureAwait(false);
            PreviewResponse = preview;
            PreviewRows.Clear();
            PreviewRows.AddRange(preview.Rows);
            AssistantContextSummary = BuildAssistantContextSummary(preview);
            StatusHeadline = preview.IsDuplicate ? "Duplicate detected" : "Preview ready";
            StatusMessage = preview.StatusMessage;
            ActiveStep = 1;
            ImportProgress = preview.IsDuplicate ? 55 : 75;

            if (preview.IsDuplicate)
            {
                await ShowToastAsync("Duplicate QuickBooks file", preview.StatusMessage).ConfigureAwait(false);
            }
            else
            {
                await ShowToastAsync("Preview loaded", preview.StatusMessage).ConfigureAwait(false);
            }
        }
        catch (Exception ex)
        {
            StatusHeadline = "Preview failed";
            StatusMessage = ex.Message;
            await ShowToastAsync(StatusHeadline, StatusMessage).ConfigureAwait(false);
        }
        finally
        {
            IsBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShowToastAsync(string title, string content)
    {
        if (ToastRef is null)
        {
            return;
        }

        await ToastRef.ShowAsync(new ToastModel
        {
            Title = title,
            Content = content,
            ShowCloseButton = true,
            Timeout = 4000,
            CssClass = "e-toast-info"
        }).ConfigureAwait(false);
    }

    private async Task<bool> EnsureSelectedFileIsValidAsync(string operation)
    {
        var actionPhrase = string.Equals(operation, "commit", StringComparison.OrdinalIgnoreCase)
            ? "committing"
            : "previewing";

        if (SelectedFileBytes is null || SelectedFileBytes.Length == 0)
        {
            StatusHeadline = "Missing file";
            StatusMessage = $"Select a QuickBooks export before {actionPhrase}.";
            ShowCommitDialog = false;
            await ShowToastAsync("QuickBooks import", StatusMessage).ConfigureAwait(false);
            await InvokeAsync(StateHasChanged);
            return false;
        }

        if (!IsSupportedFileName(SelectedFileName))
        {
            StatusHeadline = "Unsupported file type";
            StatusMessage = "QuickBooks imports support CSV or Excel files only.";
            PreviewRows.Clear();
            PreviewResponse = null;
            AssistantContextSummary = "No QuickBooks preview has been loaded yet.";
            AssistantAnswer = "Load a QuickBooks preview, then ask a question about the rows or troubleshooting steps.";
            ActiveStep = 0;
            ImportProgress = 0;
            ShowCommitDialog = false;
            await ShowToastAsync("QuickBooks import", StatusMessage).ConfigureAwait(false);
            await InvokeAsync(StateHasChanged);
            return false;
        }

        return true;
    }

    public async Task ClearSelectionAsync()
    {
        SelectedFileBytes = null;
        SelectedFileName = string.Empty;
        FileInputRenderKey = Guid.NewGuid().ToString("N");
        PreviewRows.Clear();
        PreviewResponse = null;
        AssistantQuestion = string.Empty;
        AssistantAnswer = "Load a QuickBooks preview, then ask a question about the rows or troubleshooting steps.";
        AssistantContextSummary = "No QuickBooks preview has been loaded yet.";
        StatusHeadline = "Ready";
        StatusMessage = "Choose a QuickBooks export to begin.";
        ActiveStep = 0;
        ImportProgress = 0;
        ShowCommitDialog = false;

        await InvokeAsync(StateHasChanged);
    }

    private async Task AskAssistantAsync()
    {
        if (PreviewResponse is null)
        {
            AssistantAnswer = "Load a QuickBooks preview before asking the assistant a question.";
            await ShowToastAsync("QuickBooks import assistant", AssistantAnswer).ConfigureAwait(false);
            return;
        }

        if (string.IsNullOrWhiteSpace(AssistantQuestion))
        {
            AssistantAnswer = "Enter a question about the import, such as duplicate blocking, column mapping, or date parsing.";
            await ShowToastAsync("QuickBooks import assistant", AssistantAnswer).ConfigureAwait(false);
            return;
        }

        try
        {
            IsAskingAssistant = true;
            ImportProgress = Math.Max(ImportProgress, 80);
            await InvokeAsync(StateHasChanged);

            var response = await ImportApi.AskAsync(new QuickBooksImportGuidanceRequest(AssistantQuestion, PreviewResponse), CancellationToken.None).ConfigureAwait(false);
            AssistantAnswer = response.Answer;
            AssistantContextSummary = response.ContextSummary;
            ActiveStep = Math.Max(ActiveStep, 2);
            await ShowToastAsync(response.UsedFallback ? "QuickBooks guidance" : "QuickBooks assistant", response.Answer).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            AssistantAnswer = ex.Message;
            await ShowToastAsync("QuickBooks import assistant", AssistantAnswer).ConfigureAwait(false);
        }
        finally
        {
            IsAskingAssistant = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task ClearAssistantAsync()
    {
        AssistantQuestion = string.Empty;
        AssistantAnswer = PreviewResponse is null
            ? "Load a QuickBooks preview, then ask a question about the rows or troubleshooting steps."
            : "Ask a question about duplicate detection, column mapping, dates, or commit errors.";
        AssistantContextSummary = BuildAssistantContextSummary(PreviewResponse);
        return InvokeAsync(StateHasChanged);
    }

    private static string BuildAssistantContextSummary(QuickBooksImportPreviewResponse? preview)
    {
        if (preview is null)
        {
            return "No QuickBooks preview has been loaded yet.";
        }

        return $"{preview.FileName} for {preview.SelectedEnterprise} FY {preview.SelectedFiscalYear}: {preview.TotalRows} rows parsed, {preview.DuplicateRows} duplicates flagged, file duplicate = {preview.IsDuplicate}.";
    }

    private static bool IsSupportedFileName(string fileName)
    {
        var extension = Path.GetExtension(fileName);
        return SupportedFileExtensions.Contains(extension);
    }

    private async Task LoadRoutingWorkspaceAsync()
    {
        try
        {
            IsRoutingBusy = true;
            RoutingStatusMessage = "Loading QuickBooks routing configuration and import history...";
            ImportHistoryStatusMessage = "Loading QuickBooks import history...";
            await InvokeAsync(StateHasChanged);

            var configurationTask = ImportApi.GetRoutingConfigurationAsync(CancellationToken.None);
            var historyTask = ImportApi.GetImportHistoryAsync(CancellationToken.None);
            await Task.WhenAll(configurationTask, historyTask).ConfigureAwait(false);

            var configuration = await configurationTask.ConfigureAwait(false);
            var history = await historyTask.ConfigureAwait(false);

            ReplaceRoutingConfiguration(configuration);
            ReplaceImportHistory(history);

            RoutingStatusMessage = configuration.StatusMessage;
            ImportHistoryStatusMessage = history.StatusMessage;
        }
        catch (Exception ex)
        {
            RoutingStatusMessage = ex.Message;
            ImportHistoryStatusMessage = ex.Message;
            await ShowToastAsync("QuickBooks routing", ex.Message).ConfigureAwait(false);
        }
        finally
        {
            IsRoutingBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadImportHistoryAsync()
    {
        try
        {
            IsRoutingBusy = true;
            ImportHistoryStatusMessage = "Loading QuickBooks import history...";
            await InvokeAsync(StateHasChanged);

            var history = await ImportApi.GetImportHistoryAsync(CancellationToken.None).ConfigureAwait(false);
            ReplaceImportHistory(history);
            ImportHistoryStatusMessage = history.StatusMessage;
        }
        catch (Exception ex)
        {
            ImportHistoryStatusMessage = ex.Message;
            await ShowToastAsync("QuickBooks routing", ex.Message).ConfigureAwait(false);
        }
        finally
        {
            IsRoutingBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void AddRoutingRule()
    {
        RoutingRules.Add(new QuickBooksRoutingRuleDefinition
        {
            Name = "New routing rule",
            Priority = RoutingRules.Count == 0 ? 10 : RoutingRules.Max(item => item.Priority) + 10,
            IsActive = true,
            TargetEnterprise = GetDefaultRoutingEnterprise()
        });
    }

    private void RemoveRoutingRule(QuickBooksRoutingRuleDefinition rule)
    {
        RoutingRules.Remove(rule);
    }

    private void AddAllocationProfile()
    {
        var profile = new QuickBooksAllocationProfileDefinition
        {
            Name = "New allocation profile",
            IsActive = true
        };

        profile.Targets.Add(new QuickBooksAllocationTargetDefinition
        {
            EnterpriseName = GetDefaultRoutingEnterprise(),
            AllocationPercent = 100m
        });

        AllocationProfiles.Add(profile);
    }

    private void RemoveAllocationProfile(QuickBooksAllocationProfileDefinition profile)
    {
        AllocationProfiles.Remove(profile);

        foreach (var rule in RoutingRules.Where(item => item.AllocationProfileId == profile.Id))
        {
            rule.AllocationProfileId = null;
        }
    }

    private void AddAllocationTarget(QuickBooksAllocationProfileDefinition profile)
    {
        profile.Targets.Add(new QuickBooksAllocationTargetDefinition
        {
            EnterpriseName = GetDefaultRoutingEnterprise(),
            AllocationPercent = 0m
        });
    }

    private void RemoveAllocationTarget(QuickBooksAllocationProfileDefinition profile, QuickBooksAllocationTargetDefinition target)
    {
        profile.Targets.Remove(target);
    }

    private async Task SaveRoutingConfigurationAsync()
    {
        try
        {
            IsRoutingBusy = true;
            RoutingStatusMessage = "Saving QuickBooks routing configuration...";
            await InvokeAsync(StateHasChanged);

            var response = await ImportApi.SaveRoutingConfigurationAsync(new QuickBooksRoutingConfigurationRequest
            {
                Rules = RoutingRules.Select(CloneRule).ToList(),
                AllocationProfiles = AllocationProfiles.Select(CloneProfile).ToList()
            }, CancellationToken.None).ConfigureAwait(false);

            ReplaceRoutingConfiguration(response);
            RoutingStatusMessage = response.StatusMessage;
            await ShowToastAsync("QuickBooks routing", response.StatusMessage).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            RoutingStatusMessage = ex.Message;
            await ShowToastAsync("QuickBooks routing", ex.Message).ConfigureAwait(false);
        }
        finally
        {
            IsRoutingBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReapplyRoutingAsync(QuickBooksImportHistoryItem item)
    {
        try
        {
            IsRoutingBusy = true;
            ReroutingSourceFileId = item.SourceFileId;
            ImportHistoryStatusMessage = $"Reapplying routing for {item.FileName}...";
            await InvokeAsync(StateHasChanged);

            var response = await ImportApi.ReapplyRoutingAsync(new QuickBooksHistoricalRerouteRequest
            {
                SourceFileId = item.SourceFileId
            }, CancellationToken.None).ConfigureAwait(false);

            ImportHistoryStatusMessage = response.StatusMessage;
            await LoadImportHistoryAsync().ConfigureAwait(false);
            await ShowToastAsync("QuickBooks routing", response.StatusMessage).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            ImportHistoryStatusMessage = ex.Message;
            await ShowToastAsync("QuickBooks routing", ex.Message).ConfigureAwait(false);
        }
        finally
        {
            ReroutingSourceFileId = null;
            IsRoutingBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ReplaceRoutingConfiguration(QuickBooksRoutingConfigurationResponse configuration)
    {
        RoutingRules.Clear();
        RoutingRules.AddRange(configuration.Rules.Select(CloneRule));

        AllocationProfiles.Clear();
        AllocationProfiles.AddRange(configuration.AllocationProfiles.Select(CloneProfile));
    }

    private void ReplaceImportHistory(QuickBooksImportHistoryResponse history)
    {
        ImportHistoryItems.Clear();
        ImportHistoryItems.AddRange(history.Items.Select(item => new QuickBooksImportHistoryItem
        {
            SourceFileId = item.SourceFileId,
            BatchId = item.BatchId,
            FileName = item.FileName,
            ScopeSummary = item.ScopeSummary,
            RowCount = item.RowCount,
            ImportedAtUtc = item.ImportedAtUtc
        }));
    }

    private QuickBooksRoutingRuleDefinition CloneRule(QuickBooksRoutingRuleDefinition rule)
        => new()
        {
            Id = rule.Id,
            Name = rule.Name,
            Description = rule.Description,
            Priority = rule.Priority,
            IsActive = rule.IsActive,
            SourceFilePattern = rule.SourceFilePattern,
            DefaultEnterprisePattern = rule.DefaultEnterprisePattern,
            AccountPattern = rule.AccountPattern,
            MemoPattern = rule.MemoPattern,
            NamePattern = rule.NamePattern,
            SplitAccountPattern = rule.SplitAccountPattern,
            TargetEnterprise = rule.TargetEnterprise,
            AllocationProfileId = rule.AllocationProfileId
        };

    private QuickBooksAllocationProfileDefinition CloneProfile(QuickBooksAllocationProfileDefinition profile)
        => new()
        {
            Id = profile.Id,
            Name = profile.Name,
            Description = profile.Description,
            IsActive = profile.IsActive,
            Targets = profile.Targets.Select(target => new QuickBooksAllocationTargetDefinition
            {
                Id = target.Id,
                EnterpriseName = target.EnterpriseName,
                AllocationPercent = target.AllocationPercent
            }).ToList()
        };

    private IEnumerable<QuickBooksAllocationProfileOption> GetAllocationProfileOptions()
    {
        yield return new QuickBooksAllocationProfileOption(null, "No allocation profile");

        foreach (var profile in AllocationProfiles.OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase))
        {
            yield return new QuickBooksAllocationProfileOption(profile.Id, profile.Name);
        }
    }

    private string GetDefaultRoutingEnterprise()
    {
        if (!string.IsNullOrWhiteSpace(WorkspaceState.SelectedEnterprise)
            && RoutingEnterpriseOptions.Contains(WorkspaceState.SelectedEnterprise, StringComparer.OrdinalIgnoreCase))
        {
            return WorkspaceState.SelectedEnterprise;
        }

        return RoutingEnterpriseOptions.FirstOrDefault() ?? WorkspaceEnterpriseCatalog.WaterUtility;
    }

    private static string GetRuleTitle(QuickBooksRoutingRuleDefinition rule)
        => string.IsNullOrWhiteSpace(rule.Name) ? "Unnamed rule" : rule.Name;

    private static string GetRuleSubtitle(QuickBooksRoutingRuleDefinition rule)
        => $"Priority {rule.Priority} | {(rule.IsActive ? "Active" : "Inactive")}";

    private static string GetProfileTitle(QuickBooksAllocationProfileDefinition profile)
        => string.IsNullOrWhiteSpace(profile.Name) ? "Unnamed profile" : profile.Name;

    private static string GetProfileSubtitle(QuickBooksAllocationProfileDefinition profile)
        => $"{profile.Targets.Count} target(s) | {(profile.IsActive ? "Active" : "Inactive")}";

    private static string GetAllocationPercentDisplay(QuickBooksAllocationProfileDefinition profile)
        => $"{profile.Targets.Sum(item => item.AllocationPercent):0.##}%";

    private static string GetHistorySubtitle(QuickBooksImportHistoryItem item)
        => $"{item.RowCount} row(s) | {item.ScopeSummary} | Imported {item.ImportedAtUtc}";

    private sealed record QuickBooksAllocationProfileOption(long? Id, string Name);
}