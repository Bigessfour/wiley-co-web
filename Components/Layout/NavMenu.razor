<div class="app-nav-shell" role="navigation" aria-label="Primary workspace navigation">
    <SfListView ID="app-shell-navigation-list"
                CssClass="app-nav-list"
                ShowHeader="true"
                HeaderTitle="Workspace navigation"
                DataSource="@NavigationItems"
                EnableVirtualization="true">
                @* EnableVirtualization: future-proofs the nav list as workspace routes grow *@
        <Template Context="navItem">
            <SfTooltip Content="@navItem.Tooltip"
                       OpensOn="Hover"
                       Position="Position.RightCenter"
                       ShowTipPointer="true"
                       OpenDelay="300"
                       CloseDelay="100">
                       @* OpenDelay/CloseDelay: prevents tooltip flickering on fast cursor sweeps across the nav rail *@
                <NavLink class="app-nav-link"
                         href="@navItem.Href"
                         Match="@navItem.Match"
                         aria-label="@navItem.Label"
                         aria-current="@(IsNavItemActive(navItem) ? "page" : null)">
                    <span class="app-nav-link-index" aria-hidden="true">@navItem.Index</span>
                    <span class="app-nav-link-label">@navItem.Label</span>
                </NavLink>
            </SfTooltip>
        </Template>
    </SfListView>

    <div class="app-sidebar-footer" aria-label="Version information">
        <span class="e-badge e-badge-dark" role="status">Syncfusion 33.2.3</span>
        <span class="e-badge e-badge-info" role="status">AWS Amplify</span>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager Nav { get; set; } = default!;

    private static readonly IReadOnlyList<WorkspaceNavItem> NavigationItems =
    [
        new("01", "Workspace Overview", "/wiley-workspace", NavLinkMatch.All, "Open the workspace overview"),
        new("02", "Break-Even", "/wiley-workspace/break-even", NavLinkMatch.Prefix, "Inspect rate balance and gauge inputs"),
        new("03", "Apartment Config", "/wiley-workspace/apartment-config", NavLinkMatch.Prefix, "Jump to the apartment configuration section"),
        new("04", "Rates", "/wiley-workspace/rates", NavLinkMatch.Prefix, "Adjust the live rate controls"),
        new("05", "QuickBooks Import", "/wiley-workspace/quickbooks-import", NavLinkMatch.Prefix, "Stage and validate QuickBooks exports"),
        new("06", "Scenario Planner", "/wiley-workspace/scenario", NavLinkMatch.Prefix, "Model what-if scenarios and saved snapshots"),
        new("07", "Customer Viewer", "/wiley-workspace/customers", NavLinkMatch.Prefix, "Review customer impacts and exports"),
        new("08", "Affordability", "/wiley-workspace/affordability", NavLinkMatch.Prefix, "Inspect bill burden versus MHI"),
        new("09", "Debt Coverage", "/wiley-workspace/debt-coverage", NavLinkMatch.Prefix, "Inspect DSCR and covenant headroom"),
        new("10", "Capital Gap", "/wiley-workspace/capital-gap", NavLinkMatch.Prefix, "Inspect capital needs against rate revenue"),
        new("11", "Reserve Trajectory", "/wiley-workspace/reserve-trajectory", NavLinkMatch.Prefix, "Inspect reserve forecast and policy floor"),
        new("12", "Trends", "/wiley-workspace/trends", NavLinkMatch.Prefix, "Inspect projected rate movement"),
        new("13", "Decision Support", "/wiley-workspace/decision-support", NavLinkMatch.Prefix, "Open Jarvis decision support"),
        new("14", "Data Dashboard", "/wiley-workspace/data-dashboard", NavLinkMatch.Prefix, "Open the executive dashboard")
    ];

    /// <summary>
    /// Returns true when the nav item matches the current URL so we can emit
    /// <c>aria-current="page"</c> for screen readers.  Mirrors the same logic
    /// Blazor's NavLink uses internally for the "active" CSS class.
    /// </summary>
    private bool IsNavItemActive(WorkspaceNavItem item)
    {
        var relativeCurrent = Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/');
        var relativeHref    = item.Href.TrimStart('/');

        if (item.Match == NavLinkMatch.All)
        {
            return string.Equals(relativeCurrent, relativeHref, StringComparison.OrdinalIgnoreCase);
        }

        return relativeCurrent.StartsWith(relativeHref, StringComparison.OrdinalIgnoreCase)
               && (relativeCurrent.Length == relativeHref.Length
                   || relativeCurrent[relativeHref.Length] == '/');
    }

    private sealed record WorkspaceNavItem(string Index, string Label, string Href, NavLinkMatch Match, string Tooltip);
}

