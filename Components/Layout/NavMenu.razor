<div class="app-nav-shell">
    <SfListView ID="app-shell-navigation-list"
                CssClass="app-nav-list"
                ShowHeader="true"
                HeaderTitle="Workspace navigation"
                DataSource="@NavigationItems">
        <Template Context="navItem">
            <SfTooltip Content="@navItem.Tooltip"
                       OpensOn="Hover"
                       Position="Position.RightCenter"
                       ShowTipPointer="true">
                <NavLink class="app-nav-link" href="@navItem.Href" Match="@navItem.Match" aria-label="@navItem.Label">
                    <span class="app-nav-link-index" aria-hidden="true">@navItem.Index</span>
                    <span class="app-nav-link-label">@navItem.Label</span>
                </NavLink>
            </SfTooltip>
        </Template>
    </SfListView>

    <div class="app-sidebar-footer">
        <span class="e-badge e-badge-dark">Syncfusion 33.2.3</span>
        <span class="e-badge e-badge-info">AWS Amplify</span>
    </div>
</div>

@code {
    private static readonly IReadOnlyList<WorkspaceNavItem> NavigationItems =
    [
        new("01", "Workspace Overview", "/wiley-workspace", NavLinkMatch.All, "Open the workspace overview"),
        new("02", "Break-Even", "/wiley-workspace/break-even", NavLinkMatch.Prefix, "Inspect rate balance and gauge inputs"),
        new("03", "Rates", "/wiley-workspace/rates", NavLinkMatch.Prefix, "Adjust the live rate controls"),
        new("04", "QuickBooks Import", "/wiley-workspace/quickbooks-import", NavLinkMatch.Prefix, "Stage and validate QuickBooks exports"),
        new("05", "Scenario Planner", "/wiley-workspace/scenario", NavLinkMatch.Prefix, "Model what-if scenarios and saved snapshots"),
        new("06", "Customer Viewer", "/wiley-workspace/customers", NavLinkMatch.Prefix, "Review customer impacts and exports"),
        new("07", "Affordability", "/wiley-workspace/affordability", NavLinkMatch.Prefix, "Inspect bill burden versus MHI"),
        new("08", "Debt Coverage", "/wiley-workspace/debt-coverage", NavLinkMatch.Prefix, "Inspect DSCR and covenant headroom"),
        new("09", "Capital Gap", "/wiley-workspace/capital-gap", NavLinkMatch.Prefix, "Inspect capital needs against rate revenue"),
        new("10", "Trends", "/wiley-workspace/trends", NavLinkMatch.Prefix, "Inspect projected rate movement"),
        new("11", "Decision Support", "/wiley-workspace/decision-support", NavLinkMatch.Prefix, "Open Jarvis decision support"),
        new("12", "Data Dashboard", "/wiley-workspace/data-dashboard", NavLinkMatch.Prefix, "Open the executive dashboard")
    ];

    private sealed record WorkspaceNavItem(string Index, string Label, string Href, NavLinkMatch Match, string Tooltip);
}

