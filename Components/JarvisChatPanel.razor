@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Cards
@using Syncfusion.Blazor.Inputs

<div class="jarvis-chat-panel">
    <SfCard>
        <CardHeader Title="Decision Support" SubTitle="Live workspace guidance" />
        <CardContent>
            <div class="flex flex-col gap-4">
                <div class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 px-3 py-2 text-xs text-slate-600">
                    <div class="font-semibold text-slate-700">Operational status</div>
                    <div>@StatusText</div>
                </div>

                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700">
                    <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Current brief</div>
                    <div class="mt-2 text-sm leading-6 text-slate-700">@PrimaryBrief</div>
                </div>

                <div class="grid gap-3">
                    @foreach (var insight in Insights)
                    {
                        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                            <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">@insight.Label</div>
                            <div class="mt-2 text-xl font-semibold text-slate-900">@insight.Value</div>
                            <div class="mt-1 text-sm leading-5 text-slate-600">@insight.Description</div>
                        </div>
                    }
                </div>

                <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Recommended actions</div>
                            <div class="mt-1 text-sm text-slate-600">@KnowledgeStatus</div>
                        </div>
                        <SfButton CssClass="e-flat" Disabled="@IsKnowledgeBusy" OnClick="RefreshKnowledgeFromButtonAsync">Refresh</SfButton>
                    </div>
                    <div class="mt-3 space-y-3">
                        @foreach (var action in RecommendedActions)
                        {
                            <div class="rounded-xl bg-slate-50 px-3 py-3">
                                <div class="text-sm font-semibold text-slate-900">@action.Title</div>
                                <div class="mt-1 text-sm leading-5 text-slate-600">@action.Description</div>
                            </div>
                        }
                    </div>
                </div>

                @if (IsSecureJarvisEnabled)
                {
                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <div>
                                <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Jarvis chat</div>
                                <div class="mt-1 text-sm text-slate-600">Secure API-backed chat using the same workspace snapshot as the rest of the shell.</div>
                            </div>
                            <div class="rounded-full bg-slate-50 px-3 py-1 text-xs text-slate-600">
                                <span class="font-semibold text-slate-700">Signed in as:</span> @CurrentUserLabel
                            </div>
                        </div>

                        <div class="mt-3 rounded-2xl border border-slate-200 bg-gradient-to-br from-white via-slate-50 to-sky-50 p-2">
                            <div id="jarvis-chat-ui" class="h-[19rem] sm:h-[24rem] overflow-hidden rounded-xl border border-slate-200 bg-white">
                                <SfAIAssistView ID="jarvis-chat-surface"
                                                Height="100%"
                                                Width="100%"
                                                @bind-Prompt="ChatQuestion"
                                                PromptPlaceholder="Ask about the workspace, codebase, or AI tools"
                                                PromptRequested="OnPromptRequestedAsync"
                                                Prompts="ChatPrompts"
                                                PromptSuggestions="PromptSuggestions"
                                                PromptSuggestionsHeader="Suggested prompts">
                                    <ChildContent>
                                        <AssistViews>
                                            <AssistView Header="JARVIS" IconCss="e-icons e-ai-chat" ShowClearButton="true">
                                                <BannerTemplate>
                                                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
                                                        <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Current workspace</div>
                                                        <div class="mt-2 text-sm text-slate-700">@ChatContextSummary</div>
                                                    </div>
                                                </BannerTemplate>
                                                <PromptItemTemplate>
                                                    <div class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm">
                                                        <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">You</div>
                                                        <div class="mt-1 whitespace-pre-line text-slate-700">@context.Prompt</div>
                                                    </div>
                                                </PromptItemTemplate>
                                                <ResponseItemTemplate>
                                                    <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm shadow-sm">
                                                        <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-sky-600">Jarvis</div>
                                                        <div class="mt-1 whitespace-pre-line text-slate-700">@context.Response</div>
                                                    </div>
                                                </ResponseItemTemplate>
                                            </AssistView>
                                        </AssistViews>
                                    </ChildContent>
                                </SfAIAssistView>
                            </div>
                        </div>

                        <div class="mt-3 rounded-lg bg-slate-50 px-3 py-2 text-xs text-slate-600">
                            <span class="font-semibold text-slate-700">Scope:</span> @CurrentConversationLabel
                            <span class="ml-3 font-semibold text-slate-700">Profile summary:</span> @CurrentProfileSummary
                        </div>

                        <div class="mt-3 space-y-3">
                            <div id="jarvis-conversation-history" class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Conversation history</div>
                                @if (ChatTranscript.Count == 0)
                                {
                                    <div class="mt-2 text-sm text-slate-500">No prior Jarvis turns yet.</div>
                                }
                                else
                                {
                                    <div class="mt-3 space-y-3">
                                        @foreach (var message in ChatTranscript)
                                        {
                                            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm">
                                                <div class="text-[11px] font-semibold uppercase tracking-[0.22em] @(IsAssistantMessage(message.Role) ? "text-sky-600" : "text-slate-500")">@(IsAssistantMessage(message.Role) ? "Jarvis" : "You")</div>
                                                <div class="mt-1 whitespace-pre-line text-slate-700">@message.Content</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <div id="jarvis-recommendation-history" class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Recommendation history</div>
                                <div class="mt-1 text-xs text-slate-500">@RecommendationHistoryStatus</div>
                                @if (RecommendationHistory.Count == 0)
                                {
                                    <div class="mt-2 text-sm text-slate-500">No saved recommendations yet for this workspace scope.</div>
                                }
                                else
                                {
                                    <div class="mt-3 space-y-2">
                                        @foreach (var entry in RecommendationHistory)
                                        {
                                            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm">
                                                <div class="flex flex-wrap items-center justify-between gap-2 text-[11px] uppercase tracking-[0.16em] text-slate-500">
                                                    <span>@entry.UserDisplayName</span>
                                                    <span>@DateTimeOffset.Parse(entry.CreatedAtUtc).ToLocalTime().ToString("g")</span>
                                                </div>
                                                <div class="mt-2 text-xs text-slate-500">Q: @entry.Question</div>
                                                <div class="mt-1 whitespace-pre-line text-slate-700">@entry.Recommendation</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <SfTextBox ID="jarvis-question-input"
                                       Placeholder="Ask about the workspace, codebase, or AI tools"
                                       FloatLabelType="FloatLabelType.Auto"
                                       Multiline="true"
                                       Rows="4"
                                       ShowClearButton="true"
                                       Width="100%"
                                       @bind-Value="ChatQuestion" />

                            <div class="flex flex-wrap gap-3">
                                <SfButton CssClass="e-primary" IsPrimary="true" Disabled="@(!CanAskChat)" OnClick="AskChatAsync">Ask Jarvis</SfButton>
                                <SfButton Disabled="@IsChatBusy" OnClick="ResetChatAsync">Reset Thread</SfButton>
                            </div>

                            <div id="jarvis-chat-answer" class="rounded-xl bg-slate-50 p-3 text-sm text-slate-700">
                                <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Context</div>
                                <div class="mt-1">@ChatContextSummary</div>
                                <div class="mt-3 whitespace-pre-line">@ChatAnswer</div>
                            </div>

                            <div class="grid gap-2 text-xs text-slate-500 sm:grid-cols-2">
                                <div>Conversation scope: @CurrentConversationLabel</div>
                                <div>Turn count: @ChatTranscript.Count</div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-600">
                        <div class="font-semibold text-slate-700">Delivery note</div>
                        <div class="mt-1">This panel uses the same workspace state the rest of the UI reads and can call the server-side Semantic Kernel assistant when the xAI key is configured.</div>
                    </div>
                }
            </div>
        </CardContent>
    </SfCard>
</div>