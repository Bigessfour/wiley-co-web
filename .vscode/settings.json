{
  "dotnet.defaultSolution": "WileyCoWeb.slnx",
  "terminal.integrated.env.osx": {
    "PATH": "/opt/homebrew/bin:${env:PATH}",
    "WILEYCO_E2E_BASE_URL": "http://localhost:5230"
  },
  "terminal.integrated.env.windows": {
    "WILEYCO_E2E_BASE_URL": "http://localhost:5230"
  },
  "terminal.integrated.profiles.osx": {
    "PowerShell 7.6": {
      "path": "/opt/homebrew/bin/pwsh",
      "args": ["-NoLogo"]
    },
    "zsh": {
      "path": "/bin/zsh"
    }
  },
  "terminal.integrated.defaultProfile.osx": "PowerShell 7.6",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.automationProfile.osx": {
    "path": "/opt/homebrew/bin/pwsh",
    "args": ["-NoLogo"]
  },
  "terminal.integrated.automationProfile.windows": {
    "source": "PowerShell",
    "args": ["-NoLogo"]
  },
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },
  "playwright.showTrace": true,
  "playwright.pickLocatorCopyToClipboard": false,
  "playwrightrunner.playwrightCommand": "npx playwright",
  "playwrightrunner.playwrightConfigPath": "playwright.config.ts",
  "playwrightrunner.playwrightRunProject": "chromium",
  "playwrightrunner.playwrightDebugProject": "chromium",
  "playwrightrunner.playwrightInspectProject": "chromium",
  "playwrightrunner.codeLensSelector": "tests/playwright/**/*.spec.ts",
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "__remote_check__": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "__remote_check__": true
  },
  "dotnetAcquisitionExtension.sharedExistingDotnetPath": "C:\\Program Files\\dotnet\\dotnet.exe",
  "csharp-dev-tools.roslyn.projectOrSolutionFiles": [
    "c:\\Users\\biges\\Desktop\\WW AWS\\WileyCoWeb.slnx"
  ],
  "chat.tools.terminal.autoApprove": {
    "rg": true,
    "rg --files": true,
    "where rg": true
  },
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,
  "FSharp.suggestGitignore": false,
  "workbench.settings.alwaysShowAdvancedSettings": true,

  // Complete AWS Toolkit Extension Configuration for this Wiley.co Amplify + Aurora project
  "aws.profile": "default",
  "aws.region": "us-east-2",
  "aws.explorer.enabled": true,
  "aws.resources.enabled": true,
  "aws.explorer.showRegion": true,
  "aws.lambda.enableCodeLenses": true,
  "aws.suppressPrompts": {
    "createCredentialsProfile": true,
    "showRegionPrompt": true
  },
  "aws.amplify.showAmplifyView": true,
  "aws.resources.filterByTag": {
    "awsApplication": "arn:aws:resource-groups:us-east-2:570912405222:group/Wiley-Widget/08d8t52ldwuciha57h7wqvq8cb"
  },
  "aws.aurora.showInExplorer": true
}
