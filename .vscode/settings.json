{
  "dotnet.defaultSolution": "WileyCoWeb.slnx",
  "chat.mcp.autostart": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
