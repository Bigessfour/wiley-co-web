{
  "dotnet.defaultSolution": "WileyCoWeb.slnx",
  "terminal.integrated.env.osx": {
    "PATH": "/opt/homebrew/bin:${env:PATH}"
  },
  "terminal.integrated.profiles.osx": {
    "PowerShell 7.6": {
      "path": "/opt/homebrew/bin/pwsh",
      "args": [
        "-NoLogo"
      ]
    },
    "zsh": {
      "path": "/bin/zsh"
    }
  },
  "terminal.integrated.defaultProfile.osx": "PowerShell 7.6",
  "terminal.integrated.automationProfile.osx": {
    "path": "/opt/homebrew/bin/pwsh",
    "args": [
      "-NoLogo"
    ]
  },
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "__remote_check__": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "__remote_check__": true
  },
  "dotnetAcquisitionExtension.sharedExistingDotnetPath": "/Users/stephenmckitrick/.dotnet-x64/dotnet",
  "csharp-dev-tools.roslyn.projectOrSolutionFiles": ["WileyCoWeb.slnx"],
  "chat.tools.terminal.autoApprove": {
    "rg": true,
    "rg --files": true,
    "where rg": true
  },
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": false,
  "FSharp.suggestGitignore": false,
  "workbench.settings.alwaysShowAdvancedSettings": true
}
