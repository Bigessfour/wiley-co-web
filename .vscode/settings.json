{
  "dotnet.defaultSolution": "WileyCoWeb.slnx",
  "terminal.integrated.env.osx": {
    "PATH": "/opt/homebrew/bin:${env:PATH}",
    "WILEYCO_E2E_BASE_URL": "http://localhost:5230"
  },
  "terminal.integrated.env.windows": {
    "WILEYCO_E2E_BASE_URL": "http://localhost:5230"
  },
  "terminal.integrated.profiles.osx": {
    "PowerShell 7.6.1": {
      "path": "/opt/homebrew/bin/pwsh",
      "args": ["-NoLogo"]
    },
    "zsh": {
      "path": "/bin/zsh"
    }
  },
  "terminal.integrated.defaultProfile.osx": "PowerShell 7.6.1",
  "terminal.integrated.profiles.windows": {
    "PowerShell 7.6.1": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo"]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell 7.6.1",
  "terminal.integrated.automationProfile.osx": {
    "path": "/opt/homebrew/bin/pwsh",
    "args": ["-NoLogo"]
  },
  "terminal.integrated.automationProfile.windows": {
    "source": "PowerShell 7.6.1",
    "args": ["-NoLogo"]
  },
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },
  "playwright.showTrace": true,
  "playwright.pickLocatorCopyToClipboard": false,
  "playwrightrunner.playwrightCommand": "npx playwright",
  "playwrightrunner.playwrightConfigPath": "playwright.config.ts",
  "playwrightrunner.playwrightRunProject": "chromium",
  "playwrightrunner.playwrightDebugProject": "chromium",
  "playwrightrunner.playwrightInspectProject": "chromium",
  "playwrightrunner.codeLensSelector": "tests/playwright/**/*.spec.ts",
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "__remote_check__": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "__remote_check__": true
  },
  "dotnetAcquisitionExtension.sharedExistingDotnetPath": "C:\\Program Files\\dotnet\\dotnet.exe",
  "csharp-dev-tools.roslyn.projectOrSolutionFiles": [
    "c:\\Users\\biges\\Desktop\\WW AWS\\WileyCoWeb.slnx"
  ],
  "dotnet.backgroundAnalysis.analyzerDiagnosticsScope": "none",
  "dotnet.backgroundAnalysis.compilerDiagnosticsScope": "openFiles",
  "dotnet.server.suppressLspErrorToasts": true,
  "dotnet.server.suppressMiscellaneousFilesToasts": true,
  "chat.tools.terminal.autoApprove": {
    "rg": true,
    "rg --files": true,
    "where rg": true
  },
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,
  "FSharp.suggestGitignore": false,
  "workbench.settings.alwaysShowAdvancedSettings": true,

  "aws.cwl.limit": 10000,
  "aws.telemetry": false,
  "aws.suppressPrompts": {
    "createCredentialsProfile": true,
    "regionAddAutomatically": true,
    "apprunnerNotifyPricing": true,
    "apprunnerNotifyPause": true
  },
  "aws.cloudformation.telemetry.enabled": false,
  "aws.cloudformation.hover.enabled": true,
  "aws.cloudformation.completion.enabled": true,
  "aws.cloudformation.diagnostics.cfnLint.enabled": true,
  "aws.cloudformation.diagnostics.cfnLint.lintOnChange": true,
  "aws.cloudformation.diagnostics.cfnGuard.enabled": true,
  "aws.cloudformation.s3": "alwaysAsk",
  "aws.cloudformation.diagnostics.cfnLint.customization": {
    "regions": [
      "us-east-2",
      "us-east-1"
    ]
  },
  "debug.javascript.breakOnConditionalError": true,
  "debug.allowBreakpointsEverywhere": true,
  "debug.inlineValues": "on",
  "debug.showBreakpointsInOverviewRuler": true,
  "debug.showInlineBreakpointCandidates": true,
  "debug.toolBarLocation": "docked",
  "debug.console.fontSize": 14,
  "debug.console.lineHeight": 20,
  "debug.console.wordWrap": true,
  "debug.openDebug": "openOnDebugBreak",
  "debug.onTaskErrors": "showErrors",
  "debug.saveBeforeStart": "allEditorsInActiveGroup",
  "debug.terminal.clearBeforeReusing": true
}
