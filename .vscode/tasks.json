		{
			"label": "build",
			"command": "dotnet build WileyCoWeb.slnx -m:2",
			"type": "shell",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"clear": false
			}
		},
		{
			"label": "build: fast",
			"command": "dotnet build WileyCoWeb.slnx -m:2 -p:RunAnalyzers=false -p:RunAnalyzersDuringBuild=false",
