{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-wiley-widget",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/WileyCoWeb.slnx",
        "-c",
        "Debug",
        "-v",
        "minimal"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-wiley-api-terminal",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/WileyCoWeb.Api/WileyCoWeb.Api.csproj",
        "-c",
        "Debug",
        "--launch-profile",
        "WileyCoWeb.Api"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "DOTNET_ENVIRONMENT": "Development",
          "ASPNETCORE_DETAILEDERRORS": "true",
          "Logging__LogLevel__Default": "Information",
          "Logging__LogLevel__Microsoft.AspNetCore": "Information",
          "Logging__LogLevel__Microsoft.Hosting.Lifetime": "Information"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "group": "wiley-run",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "run-wiley-blazor-terminal",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/WileyCoWeb.csproj",
        "-c",
        "Debug",
        "--launch-profile",
        "http"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "DOTNET_ENVIRONMENT": "Development",
          "WILEY_WORKSPACE_API_BASE_ADDRESS": "http://localhost:5231",
          "Logging__LogLevel__Default": "Information",
          "Logging__LogLevel__Microsoft.AspNetCore": "Information",
          "Logging__LogLevel__Microsoft.Hosting.Lifetime": "Information"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "group": "wiley-run",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "run-wiley-api-blazor-parallel",
      "dependsOrder": "parallel",
      "dependsOn": ["run-wiley-api-terminal", "run-wiley-blazor-terminal"],
      "problemMatcher": []
    },
    {
      "label": "Run Wiley Widget: build then API + Blazor (terminals, Cursor-safe)",
      "dependsOrder": "sequence",
      "dependsOn": ["build-wiley-widget", "run-wiley-api-blazor-parallel"],
      "problemMatcher": []
    }
  ]
}
